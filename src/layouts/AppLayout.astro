---
import Layout from './Layout.astro';
interface Props {
	title: string;
}
const { title } = Astro.props;
const { pathname } = Astro.url;

const isActive = (path: string) => {
	if (path === '/' && pathname !== '/') return false;
	return pathname.startsWith(path);
};

// Pre-render default mobile tabs server-side to avoid flash on navigation
const _svgA = 'xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"';
const SSR_NAV_ITEMS = [
	{ id: 'dashboard', label: 'Dashboard', href: '/', icon: `<svg ${_svgA}><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>` },
	{ id: 'projects', label: 'Projects', href: '/projects', icon: `<svg ${_svgA}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>` },
	{ id: 'members', label: 'Members', href: '/members', icon: `<svg ${_svgA}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
	{ id: 'settings', label: 'Settings', href: '/settings', icon: `<svg ${_svgA}><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1-2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>` },
	{ id: 'treasury', label: 'Treasury', href: '#', icon: `<svg ${_svgA}><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>` },
	{ id: 'status', label: 'Status', href: '/status', icon: `<svg ${_svgA}><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>` },
	{ id: 'backlog', label: 'Backlog', href: '/backlog', icon: `<svg ${_svgA}><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>` },
	{ id: 'vvd', label: 'VVD', href: '/vvd', icon: `<svg ${_svgA}><polyline points="1,2 6,12 11,2"/><polyline points="11,2 15,8 19,2"/><path d="M1 14 L1 22 L10 22 Q20 22 20 18 Q20 14 10 14 Z"/></svg>` },
	{ id: 'hours', label: 'Hours', href: '/hours', icon: `<svg ${_svgA}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>` },
];
const SSR_TAB_COUNT = 4;
const ssrActiveId = (() => {
	for (const item of SSR_NAV_ITEMS) {
		if (item.href === '#') continue;
		if (item.href === '/' && pathname === '/') return item.id;
		if (item.href !== '/' && pathname.startsWith(item.href)) return item.id;
	}
	return null;
})();
const ssrVisibleTabs = SSR_NAV_ITEMS.slice(0, SSR_TAB_COUNT);
const ssrHiddenTabs = SSR_NAV_ITEMS.slice(SSR_TAB_COUNT);
const ssrMoreActive = ssrHiddenTabs.some(h => h.id === ssrActiveId);
---

<script>
	import { supabase } from '../lib/supabase';

	// Redirect invite links (implicit flow) before Supabase processes the hash
	const hashParams = new URLSearchParams(window.location.hash.substring(1));
	if (hashParams.get('type') === 'invite') {
		window.location.replace('/set-password' + window.location.hash);
	}

	// Handle password recovery (PKCE flow): Supabase exchanges the code and fires PASSWORD_RECOVERY
	supabase.auth.onAuthStateChange((event) => {
		if (event === 'PASSWORD_RECOVERY') {
			window.location.replace('/set-password');
		}
	});

	// Auth protection
	supabase.auth.getSession().then(async ({ data: { session } }) => {
		if (!session) {
			window.location.href = '/login';
		} else {
			loadSidebarProfile(session.user.id);
		}
	});

	async function loadSidebarProfile(id: string) {
		const { data } = await supabase
			.from('profiles')
			.select('username, full_name, avatar_url, tab_order')
			.eq('id', id)
			.single();

		if (data) {
			if (!data.username && window.location.pathname !== '/account') {
				window.location.href = '/account?setup=true';
			}

			const nameEls = document.querySelectorAll('.user-name');
			const avatarEls = document.querySelectorAll('.user-avatar-img');
			nameEls.forEach(el => el.textContent = data.full_name || data.username || 'Gentleman');
			avatarEls.forEach(el => {
				if (data.avatar_url) (el as HTMLImageElement).src = data.avatar_url;
			});

			// Load saved tab order for mobile nav
			if (data.tab_order?.length) {
				const existing = (data.tab_order as string[]).filter((navId: string) => ALL_NAV_ITEMS.some(i => i.id === navId));
				const missing = DEFAULT_TAB_ORDER.filter(navId => !existing.includes(navId));
				currentTabOrder = [...existing, ...missing];
			}
			// Only re-render if the order differs from what was pre-rendered server-side.
			// Unnecessary re-renders replace innerHTML and cause a layout shift (jump) on navigation.
			if (currentTabOrder.join(',') !== DEFAULT_TAB_ORDER.join(',')) {
				renderMobileTabs(currentTabOrder);
			}
		}
	}

	// Profile Dropdown
	const profileBtn = document.getElementById('profile-btn');
	const profileDropdown = document.getElementById('profile-dropdown');

	profileBtn?.addEventListener('click', (e) => {
		e.stopPropagation();
		profileDropdown?.classList.toggle('hidden');
	});

	// Logout
	const logoutBtn = document.getElementById('logout-btn');
	if (logoutBtn) {
		logoutBtn.addEventListener('click', async (e) => {
			e.preventDefault();
			await supabase.auth.signOut();
			window.location.href = '/login';
		});
	}

	// Notification System
	const notificationBtn = document.getElementById('notification-btn');
	const notificationDropdown = document.getElementById('notification-dropdown');
	const notificationList = document.getElementById('notification-list');
	const notificationBadge = document.getElementById('notification-badge');
	const markAllReadBtn = document.getElementById('mark-all-read');

	let notifications: any[] = [];
	let unreadCount = 0;

	async function loadNotifications() {
		const { data: { session } } = await supabase.auth.getSession();
		if (!session) return;

		const { data, error } = await supabase
			.from('notifications')
			.select(`*, reads:notification_reads(user_id)`)
			.order('created_at', { ascending: false })
			.limit(20);

		if (error) { console.error('Error fetching notifications:', error); return; }

		notifications = data || [];
		unreadCount = notifications.filter(n => !n.reads.some((r: any) => r.user_id === session.user.id)).length;
		updateBadge();
		renderNotifications(session.user.id);
	}

	function updateBadge() {
		if (unreadCount > 0) {
			notificationBadge?.classList.remove('hidden');
			notificationBadge!.textContent = unreadCount > 9 ? '9+' : unreadCount.toString();
		} else {
			notificationBadge?.classList.add('hidden');
		}
	}

	function renderNotifications(currentUserId: string) {
		if (!notificationList) return;
		if (notifications.length === 0) {
			notificationList.innerHTML = '<div class="empty-state">No notifications yet.</div>';
			return;
		}
		notificationList.innerHTML = notifications.map(n => {
			const isRead = n.reads.some((r: any) => r.user_id === currentUserId);
			return `
				<div class="notification-item ${isRead ? '' : 'unread'}" data-id="${n.id}">
					<div class="notification-content">
						<p class="notification-title">${n.title}</p>
						<p class="notification-text">${n.content}</p>
						<span class="notification-date">${new Date(n.created_at).toLocaleString()}</span>
					</div>
					${n.link ? `<a href="${n.link}" class="notification-link">View</a>` : ''}
				</div>
			`;
		}).join('');

		document.querySelectorAll('.notification-item.unread').forEach(item => {
			item.addEventListener('click', async (e) => {
				const id = (e.currentTarget as HTMLElement).dataset.id;
				if (id) markAsRead(id, currentUserId);
			});
		});
	}

	async function markAsRead(id: string, userId: string) {
		const { error } = await supabase
			.from('notification_reads')
			.insert({ notification_id: id, user_id: userId });
		if (!error) loadNotifications();
	}

	// Sidebar Collapsible Logic
	const sidebar = document.querySelector('.sidebar');
	const sidebarSetting = localStorage.getItem('sidebar-always-show');
	if (sidebarSetting !== 'true') sidebar?.classList.add('collapsible');

	window.addEventListener('sidebar-toggle', (e: any) => {
		if (e.detail.alwaysShow) {
			sidebar?.classList.remove('collapsible');
		} else {
			sidebar?.classList.add('collapsible');
		}
	});

	async function markAllAsRead() {
		const { data: { session } } = await supabase.auth.getSession();
		if (!session) return;
		const unreadIds = notifications
			.filter(n => !n.reads.some((r: any) => r.user_id === session.user.id))
			.map(n => ({ notification_id: n.id, user_id: session.user.id }));
		if (unreadIds.length > 0) {
			const { error } = await supabase.from('notification_reads').insert(unreadIds);
			if (!error) loadNotifications();
		}
	}

	notificationBtn?.addEventListener('click', (e) => {
		e.stopPropagation();
		notificationDropdown?.classList.toggle('hidden');
		if (!notificationDropdown?.classList.contains('hidden')) loadNotifications();
	});

	markAllReadBtn?.addEventListener('click', (e) => {
		e.stopPropagation();
		markAllAsRead();
	});

	document.addEventListener('click', () => {
		notificationDropdown?.classList.add('hidden');
	});

	loadNotifications();

	supabase
		.channel('public:notifications')
		.on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications' }, () => {
			loadNotifications();
		})
		.subscribe();

	// -------------------------------------------------------------------------
	// Mobile Navigation — Tab Bar with configurable order + "More" panel
	// -------------------------------------------------------------------------

	type NavItem = { id: string; label: string; href: string; icon: string };

	const svgAttrs = 'xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"';

	const ALL_NAV_ITEMS: NavItem[] = [
		{
			id: 'dashboard', label: 'Dashboard', href: '/',
			icon: `<svg ${svgAttrs}><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`,
		},
		{
			id: 'projects', label: 'Projects', href: '/projects',
			icon: `<svg ${svgAttrs}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
		},
		{
			id: 'members', label: 'Members', href: '/members',
			icon: `<svg ${svgAttrs}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
		},
		{
			id: 'settings', label: 'Settings', href: '/settings',
			icon: `<svg ${svgAttrs}><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1-2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
		},
		{
			id: 'treasury', label: 'Treasury', href: '#',
			icon: `<svg ${svgAttrs}><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
		},
		{
			id: 'status', label: 'Status', href: '/status',
			icon: `<svg ${svgAttrs}><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
		},
		{
			id: 'backlog', label: 'Backlog', href: '/backlog',
			icon: `<svg ${svgAttrs}><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
		},
		{
			id: 'vvd', label: 'VVD', href: '/vvd',
			icon: `<svg ${svgAttrs}><polyline points="1,2 6,12 11,2"/><polyline points="11,2 15,8 19,2"/><path d="M1 14 L1 22 L10 22 Q20 22 20 18 Q20 14 10 14 Z"/></svg>`,
		},
		{
			id: 'hours', label: 'Hours', href: '/hours',
			icon: `<svg ${svgAttrs}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
		},
	];

	const DEFAULT_TAB_ORDER = ALL_NAV_ITEMS.map(i => i.id);
	const TAB_BAR_COUNT = 4;
	let currentTabOrder = [...DEFAULT_TAB_ORDER];

	function isMobile() { return window.innerWidth <= 900; }

	function getActiveId(): string | null {
		const path = window.location.pathname;
		for (const item of ALL_NAV_ITEMS) {
			if (item.href === '#') continue;
			if (item.href === '/' && path === '/') return item.id;
			if (item.href !== '/' && path.startsWith(item.href)) return item.id;
		}
		return null;
	}

	function renderMobileTabs(order: string[]) {
		const tabsEl = document.getElementById('mobile-tabs');
		if (!tabsEl) return;

		const orderedItems = order.map(id => ALL_NAV_ITEMS.find(i => i.id === id)).filter(Boolean) as NavItem[];
		const visibleItems = orderedItems.slice(0, TAB_BAR_COUNT);
		const hiddenItems = orderedItems.slice(TAB_BAR_COUNT);
		const activeId = getActiveId();
		const moreIsActive = hiddenItems.some(h => h.id === activeId);

		const tabsHTML = visibleItems.map(item => `
			<a href="${item.href}" class="nav-item mobile-tab${item.id === activeId ? ' active' : ''}">
				${item.icon}
				<span class="nav-text">${item.label}</span>
			</a>
		`).join('');

		const moreHTML = hiddenItems.length > 0 ? `
			<button class="nav-item mobile-tab more-tab-btn${moreIsActive ? ' active' : ''}" id="more-tab-btn">
				<svg ${svgAttrs}><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
				<span class="nav-text">More</span>
			</button>
		` : '';

		tabsEl.innerHTML = tabsHTML + moreHTML;
		document.querySelector('.sidebar')?.classList.add('mobile-nav-ready');

		document.getElementById('more-tab-btn')?.addEventListener('click', () => openMorePanel(hiddenItems));
	}

	// ---- More Panel ----

	function openMorePanel(items: NavItem[]) {
		const panel = document.getElementById('more-panel');
		const navList = document.getElementById('more-nav-list');
		if (!navList || !panel) return;

		const activeId = getActiveId();
		navList.innerHTML = items.map(item => `
			<a href="${item.href}" class="more-nav-item${item.id === activeId ? ' active' : ''}">
				${item.icon}
				<span>${item.label}</span>
			</a>
		`).join('');

		panel.classList.remove('hidden');
	}

	function closeMorePanel() {
		document.getElementById('more-panel')?.classList.add('hidden');
	}

	document.getElementById('more-backdrop')?.addEventListener('click', closeMorePanel);
	document.getElementById('edit-order-btn')?.addEventListener('click', () => {
		closeMorePanel();
		openTabEditor();
	});

	// ---- Tab Order Editor ----

	function openTabEditor() {
		const editor = document.getElementById('tab-editor');
		renderSortableList(currentTabOrder);
		editor?.classList.remove('hidden');
	}

	function closeTabEditor() {
		document.getElementById('tab-editor')?.classList.add('hidden');
	}

	document.getElementById('tab-editor-backdrop')?.addEventListener('click', closeTabEditor);
	document.getElementById('close-editor-btn')?.addEventListener('click', closeTabEditor);
	document.getElementById('save-order-btn')?.addEventListener('click', saveTabOrder);

	function renderSortableList(order: string[]) {
		const list = document.getElementById('sortable-list');
		if (!list) return;

		const orderedItems = order.map(id => ALL_NAV_ITEMS.find(i => i.id === id)).filter(Boolean) as NavItem[];

		list.innerHTML = orderedItems.map((item, index) => `
			<li class="sort-item" data-id="${item.id}">
				<span class="sort-position ${index < TAB_BAR_COUNT ? 'in-bar' : 'in-more'}">${index < TAB_BAR_COUNT ? 'Tab' : 'More'}</span>
				${item.icon}
				<span class="sort-label">${item.label}</span>
				<span class="drag-handle" aria-label="Drag to reorder">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
				</span>
			</li>
		`).join('');

		initSortable(list);
		updateSortPositions(list);
	}

	function updateSortPositions(list: HTMLElement) {
		list.querySelectorAll('.sort-item').forEach((item, index) => {
			const badge = item.querySelector('.sort-position');
			if (!badge) return;
			badge.textContent = index < TAB_BAR_COUNT ? 'Tab' : 'More';
			badge.className = `sort-position ${index < TAB_BAR_COUNT ? 'in-bar' : 'in-more'}`;
		});
	}

	function initSortable(list: HTMLElement) {
		let dragging: HTMLElement | null = null;
		let startY = 0;

		list.addEventListener('pointerdown', (e) => {
			const handle = (e.target as Element).closest('.drag-handle');
			if (!handle) return;
			const item = handle.closest('.sort-item') as HTMLElement | null;
			if (!item) return;

			e.preventDefault();
			dragging = item;
			startY = e.clientY;
			item.classList.add('is-dragging');
			list.setPointerCapture(e.pointerId);
		});

		list.addEventListener('pointermove', (e) => {
			if (!dragging) return;

			const dy = e.clientY - startY;
			dragging.style.transform = `translateY(${dy}px)`;

			const draggingRect = dragging.getBoundingClientRect();
			const draggingCenterY = draggingRect.top + draggingRect.height / 2;

			const siblings = [...list.querySelectorAll('.sort-item')].filter(i => i !== dragging) as HTMLElement[];
			let nearest: HTMLElement | null = null;
			let nearestDist = Infinity;
			let insertBefore = true;

			siblings.forEach(item => {
				const rect = item.getBoundingClientRect();
				const center = rect.top + rect.height / 2;
				const dist = Math.abs(draggingCenterY - center);
				if (dist < nearestDist) {
					nearestDist = dist;
					nearest = item;
					insertBefore = draggingCenterY < center;
				}
			});

			if (nearest && nearestDist < 36) {
				if (insertBefore) {
					list.insertBefore(dragging, nearest);
				} else {
					(nearest as HTMLElement).after(dragging);
				}
				startY = e.clientY;
				dragging.style.transform = '';
				updateSortPositions(list);
			}
		});

		const endDrag = () => {
			if (!dragging) return;
			dragging.classList.remove('is-dragging');
			dragging.style.transform = '';
			dragging = null;
		};

		list.addEventListener('pointerup', endDrag);
		list.addEventListener('pointercancel', endDrag);
	}

	async function saveTabOrder() {
		const list = document.getElementById('sortable-list');
		if (!list) return;

		const newOrder = [...list.querySelectorAll('.sort-item')].map(i => (i as HTMLElement).dataset.id!);
		currentTabOrder = newOrder;

		const { data: { session } } = await supabase.auth.getSession();
		if (session) {
			await supabase.from('profiles').update({ tab_order: newOrder }).eq('id', session.user.id);
		}

		closeTabEditor();
		renderMobileTabs(currentTabOrder);
	}

	// Wire up the SSR-rendered More button before JS re-renders with user's saved order
	document.getElementById('mobile-tabs')?.addEventListener('click', (e) => {
		const btn = (e.target as Element).closest('.more-tab-btn');
		if (btn) openMorePanel(currentTabOrder.slice(TAB_BAR_COUNT).map(id => ALL_NAV_ITEMS.find(i => i.id === id)!).filter(Boolean));
	});

	// Handle orientation change / resize
	window.addEventListener('resize', () => {
		if (isMobile()) {
			renderMobileTabs(currentTabOrder);
		} else {
			document.querySelector('.sidebar')?.classList.remove('mobile-nav-ready');
			document.getElementById('more-panel')?.classList.add('hidden');
			document.getElementById('tab-editor')?.classList.add('hidden');
		}
	});

	// -------------------------------------------------------------------------
	// Koos Alberts Easter Egg
	// -------------------------------------------------------------------------

	let koosAudio: HTMLAudioElement | null = null;
	let koosTimer: ReturnType<typeof setTimeout> | null = null;

	async function triggerKoosEasterEgg() {
		// Fetch random song from storage
		const { data: songs } = await supabase.storage.from('koos-alberts').list('songs');
		if (!songs?.length) return;

		const pick = songs[Math.floor(Math.random() * songs.length)];
		const songUrl = supabase.storage.from('koos-alberts').getPublicUrl('songs/' + pick.name).data.publicUrl;

		// Fetch photo
		const { data: photos } = await supabase.storage.from('koos-alberts').list('photo');
		const photoImg = document.getElementById('koos-photo-img') as HTMLImageElement;
		if (photos?.length && photoImg) {
			photoImg.src = supabase.storage.from('koos-alberts').getPublicUrl('photo/' + photos[0].name).data.publicUrl;
			photoImg.style.display = 'block';
		} else if (photoImg) {
			photoImg.style.display = 'none';
		}

		// Stop any previous audio
		if (koosAudio) { koosAudio.pause(); koosAudio = null; }
		koosAudio = new Audio(songUrl);
		koosAudio.play().catch(() => {});

		// Show overlay
		document.getElementById('koos-overlay')?.classList.add('koos-active');

		// Reset input if triggered from search
		const inp = document.getElementById('global-search-input') as HTMLInputElement;
		if (inp) inp.value = '';

		// Auto-close after configured duration (default 15s)
		const koosDuration = Math.min(300, Math.max(5, parseInt(localStorage.getItem('koos-duration') || '15'))) * 1000;
		if (koosTimer) clearTimeout(koosTimer);
		koosTimer = setTimeout(closeKoos, koosDuration);
	}

	function closeKoos() {
		document.getElementById('koos-overlay')?.classList.remove('koos-active');
		if (koosAudio) { koosAudio.pause(); koosAudio = null; }
		if (koosTimer) { clearTimeout(koosTimer); koosTimer = null; }
	}

	// Logo click trigger
	document.getElementById('koos-logo-trigger')?.addEventListener('click', triggerKoosEasterEgg);

	// Koos overlay click to close
	document.getElementById('koos-overlay')?.addEventListener('click', closeKoos);

	// Search "koosje" + Enter trigger
	document.getElementById('global-search-input')?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') {
			const val = (e.currentTarget as HTMLInputElement).value.trim().toLowerCase();
			if (val === 'koosje') {
				e.preventDefault();
				triggerKoosEasterEgg();
			}
		}
	});
	// Global Search
	// -------------------------------------------------------------------------

	const globalSearchInput = document.getElementById('global-search-input') as HTMLInputElement;
	const searchDropdown = document.getElementById('search-results-dropdown');

	let searchTimer: ReturnType<typeof setTimeout>;
	let activeIdx = -1;

	const STATIC_PAGES = [
		{ label: 'Dashboard',  href: '/',         desc: 'Hoofdoverzicht' },
		{ label: 'Projects',   href: '/projects', desc: 'Actieve projecten' },
		{ label: 'Members',    href: '/members',   desc: 'Leden overzicht' },
		{ label: 'Backlog',    href: '/backlog',   desc: 'Product backlog & features' },
		{ label: 'Hours',      href: '/hours',     desc: 'Urenregistratie' },
		{ label: 'Status',     href: '/status',    desc: 'Status updates' },
		{ label: 'VVD',        href: '/vvd',       desc: 'VVD pagina' },
		{ label: 'Settings',   href: '/settings',  desc: 'Instellingen' },
	];

	function escapeRegex(s: string) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

	function highlight(text: string, q: string) {
		if (!q || !text) return text;
		return text.replace(new RegExp(`(${escapeRegex(q)})`, 'gi'), '<mark>$1</mark>');
	}

	function srIcon(type: string) {
		const icons: Record<string, string> = {
			page:    `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`,
			project: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
			backlog: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
			member:  `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`,
			hours:   `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
		};
		return icons[type] ?? '';
	}

	function closeSearch() {
		searchDropdown?.classList.add('hidden');
		activeIdx = -1;
	}

	function openSearch(html: string) {
		if (!searchDropdown) return;
		searchDropdown.innerHTML = html;
		searchDropdown.classList.remove('hidden');
		activeIdx = -1;
	}

	function moveActive(dir: number) {
		const items = searchDropdown?.querySelectorAll<HTMLElement>('.sr-item');
		if (!items?.length) return;
		activeIdx = Math.max(0, Math.min(activeIdx + dir, items.length - 1));
		items.forEach((el, i) => el.classList.toggle('sr-active', i === activeIdx));
		items[activeIdx].scrollIntoView({ block: 'nearest' });
	}

	globalSearchInput?.addEventListener('input', () => {
		clearTimeout(searchTimer);
		const q = globalSearchInput.value.trim();
		if (!q) { closeSearch(); return; }
		openSearch('<div class="sr-loading">Zoeken...</div>');
		searchTimer = setTimeout(() => runSearch(q), 220);
	});

	globalSearchInput?.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') { closeSearch(); globalSearchInput.blur(); return; }
		if (searchDropdown?.classList.contains('hidden')) return;
		if (e.key === 'ArrowDown') { e.preventDefault(); moveActive(1); }
		else if (e.key === 'ArrowUp') { e.preventDefault(); moveActive(-1); }
		else if (e.key === 'Enter') {
			const active = searchDropdown?.querySelector<HTMLElement>('.sr-active');
			if (active) { e.preventDefault(); active.click(); }
		}
	});

	document.addEventListener('click', (e) => {
		if (!document.getElementById('global-search-wrap')?.contains(e.target as Node)) closeSearch();
	});

	// ⌘K / Ctrl+K shortcut
	document.addEventListener('keydown', (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
			e.preventDefault();
			globalSearchInput?.focus();
			globalSearchInput?.select();
		}
	});

	async function runSearch(q: string) {
		const ql = q.toLowerCase();

		const pageHits = STATIC_PAGES.filter(p =>
			p.label.toLowerCase().includes(ql) || p.desc.toLowerCase().includes(ql)
		);

		const [projRes, backlogRes, memberRes, hoursRes] = await Promise.all([
			supabase.from('projects').select('id,title,client,category').or(`title.ilike.%${q}%,client.ilike.%${q}%`).limit(5),
			supabase.from('feature_requests').select('id,title,description,status,category').or(`title.ilike.%${q}%,description.ilike.%${q}%`).limit(5),
			supabase.from('profiles').select('id,full_name,username,avatar_url').or(`full_name.ilike.%${q}%,username.ilike.%${q}%`).limit(5),
			supabase.from('time_entries').select('id,description,date,hours').ilike('description', `%${q}%`).limit(5),
		]);

		type Group = { cat: string; icon: string; href: string; items: { label: string; sub: string; href: string; avatar?: string }[] };
		const groups: Group[] = [];

		if (pageHits.length) {
			groups.push({ cat: "Pagina's", icon: 'page', href: '', items: pageHits.map(p => ({ label: p.label, sub: p.desc, href: p.href })) });
		}
		if (projRes.data?.length) {
			groups.push({ cat: 'Projects', icon: 'project', href: '/projects', items: projRes.data.map(p => ({ label: p.title, sub: p.client || p.category || 'Intern', href: '/projects' })) });
		}
		if (backlogRes.data?.length) {
			groups.push({ cat: 'Backlog', icon: 'backlog', href: '/backlog', items: backlogRes.data.map(f => ({ label: f.title, sub: `${f.status} · ${f.category}`, href: '/backlog' })) });
		}
		if (memberRes.data?.length) {
			groups.push({ cat: 'Members', icon: 'member', href: '/members', items: memberRes.data.map(m => ({ label: m.full_name || m.username, sub: `@${m.username}`, href: '/members', avatar: m.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(m.full_name || m.username)}&background=1c1917&color=c5a059` })) });
		}
		if (hoursRes.data?.length) {
			groups.push({ cat: 'Hours', icon: 'hours', href: '/hours', items: hoursRes.data.map(e => ({ label: e.description || '—', sub: `${e.date} · ${e.hours}h`, href: '/hours' })) });
		}

		if (!groups.length) {
			openSearch(`<div class="sr-empty">Geen resultaten voor <strong>"${q}"</strong></div>`);
			return;
		}

		const html = groups.map((g, gi) => `
			${gi > 0 ? '<div class="sr-sep"></div>' : ''}
			<div class="sr-group">
				<div class="sr-group-header">
					${srIcon(g.icon)}
					<span>${g.cat}</span>
					${g.href ? `<a href="${g.href}" class="sr-view-all">Bekijk alles →</a>` : ''}
				</div>
				${g.items.map(item => `
					<a href="${item.href}" class="sr-item">
						${item.avatar
							? `<img src="${item.avatar}" class="sr-avatar" />`
							: `<span class="sr-bullet"></span>`}
						<span class="sr-text">
							<span class="sr-label">${highlight(item.label, q)}</span>
							<span class="sr-sub">${item.sub}</span>
						</span>
					</a>
				`).join('')}
			</div>
		`).join('');

		openSearch(html);
	}
</script>

