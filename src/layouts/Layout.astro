---
import { ViewTransitions } from 'astro:transitions';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Gentlemen's Dashboard" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
		<ViewTransitions />
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		/* Palette inspired by the Dribbble sample: Dark, minimal, luxury */
		--color-bg: #0a0908; /* Near black */
		--color-surface: #14110f; /* Deepest brown/grey surface */
		--color-card: #1c1917; /* Card background */
		--color-primary: #c5a059; /* Classic Gold */
		--color-primary-dim: rgba(197, 160, 89, 0.15);
		--color-text: #e7e5e4; /* Warm white */
		--color-text-muted: #a8a29e;
		--color-border: rgba(231, 229, 228, 0.08);
		
		--font-serif: 'Instrument Serif', serif;
		--font-sans: 'Inter', system-ui, sans-serif;
	}
	
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-sans);
		background: var(--color-bg);
		color: var(--color-text);
		-webkit-font-smoothing: antialiased;
	}

	body {
		min-height: 100vh;
		overflow: hidden;
	}

	h1, h2, h3, .serif {
		font-family: var(--font-serif);
		font-weight: 400;
	}

	button, input {
		font-family: inherit;
	}
</style>
