	<div id="backlog-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="modal-title" class="serif">New <span class="gold-text">Item</span></h2>
			<form id="backlog-form">
				<input type="hidden" id="item-id" name="id" />
				<div class="form-group">
					<label for="title">Title *</label>
					<input type="text" id="title" name="title" required placeholder="A brief, descriptive title" />
				</div>
				<div class="form-group">
					<label for="description">Description</label>
					<textarea id="description" name="description" rows="3" placeholder="Elaborate on the item..."></textarea>
