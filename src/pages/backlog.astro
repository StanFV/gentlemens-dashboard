	<script>
		import { supabase } from '../lib/supabase';

		const container = document.getElementById('backlog-container');
		const filterBtns = document.querySelectorAll('.filter-btn');
		const sortBtns = document.querySelectorAll('.sort-btn');
		const modal = document.getElementById('backlog-modal');
		const openModalBtn = document.getElementById('open-modal-btn');
		const cancelBtn = document.getElementById('cancel-btn');
		const form = document.getElementById('backlog-form') as HTMLFormElement;
		const userSelect = document.getElementById('assigned_to') as HTMLSelectElement;
		const modalTitleEl = document.getElementById('modal-title');
		const submitBtn = document.getElementById('submit-btn');

		let currentStatus = 'all';
		let currentSort = 'date';
		let cachedItems = [];

		const PRIORITY_ORDER = { high: 0, medium: 1, low: 2 };

		function priorityIcon(p: string) {
			if (p === 'high') return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>`;
			if (p === 'low') return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>`;
			return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>`;
		}

		function sortItems(items: any[]) {
			const sorted = [...items];
			if (currentSort === 'priority') {
				sorted.sort((a, b) => (PRIORITY_ORDER[a.priority] ?? 1) - (PRIORITY_ORDER[b.priority] ?? 1));
			} else if (currentSort === 'category') {
				sorted.sort((a, b) => (a.category ?? '').localeCompare(b.category ?? ''));
			} else {
				sorted.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
			}
			return sorted;
		}

		async function loadUsers() {
			const { data } = await supabase.from('profiles').select('id, full_name, username');
			if (data) {
				data.forEach(profile => {
					const option = document.createElement('option');
					option.value = profile.id;
					option.textContent = profile.full_name || profile.username;
					userSelect.appendChild(option);
				});
			}
		}

		async function loadItems() {
			if (!container) return;
			container.innerHTML = '<div class="loading-state">Loading the backlog...</div>';

			let query = supabase
				.from('feature_requests')
				.select(`*, assignee:profiles!assigned_to(full_name, username, avatar_url)`);

			if (currentStatus !== 'all') {
				query = query.eq('status', currentStatus);
			}

			const { data, error } = await query;

			if (error) {
				container.innerHTML = `<div class="empty-state"><p>Error: ${error.message}</p></div>`;
				return;
			}

			if (!data || data.length === 0) {
				container.innerHTML = `<div class="empty-state"><p>The backlog is clear.</p></div>`;
				return;
			}

			cachedItems = data;
			renderItems(sortItems(data));
		}

		function renderItems(items: any[]) {
			container!.innerHTML = items.map(f => {
				const assignee = f.assignee;
				const assigneeName = assignee ? (assignee.full_name || assignee.username) : 'Unassigned';
				const assigneeAvatar = assignee?.avatar_url || `https://ui-avatars.com/api/?name=${assigneeName}&background=1c1917&color=c5a059`;
				const category = f.category || 'feature';
				const priority = f.priority || 'medium';

				return `
					<div class="list-item" data-id="${f.id}">
						<div class="col-status">
							<span class="status-badge status-${f.status}">${f.status}</span>
						</div>
						<div class="col-priority">
							<span class="priority-badge priority-${priority}">
								${priorityIcon(priority)}
								${priority}
							</span>
						</div>
						<div class="col-title">
							<div class="title-group">
								<div class="title-row">
									<h3 class="item-title">${f.title}</h3>
									<span class="category-badge category-${category}">${category}</span>
								</div>
								<p class="item-desc">${f.description || 'No description provided.'}</p>
							</div>
						</div>
						<div class="col-assignee">
							<div class="assignee-pill">
								<img src="${assigneeAvatar}" class="assignee-avatar" />
								<span>${assigneeName}</span>
							</div>
						</div>
						<div class="col-date">
							<span class="date">${new Date(f.created_at).toLocaleDateString()}</span>
						</div>
						<div class="col-actions">
							<button class="btn-icon edit-btn" title="Edit">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
							</button>
							<button class="btn-icon delete-btn" title="Delete">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
							</button>
						</div>
					</div>
				`;
			}).join('');

			setupActionButtons();
		}

		function setupActionButtons() {
			document.querySelectorAll('.edit-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					const item = cachedItems.find(f => f.id === id);
					if (item) openModal(item);
				});
			});

			document.querySelectorAll('.delete-btn').forEach(btn => {
				btn.addEventListener('click', async (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					if (id && confirm('Remove this item from the backlog?')) {
						const { error } = await supabase.from('feature_requests').delete().eq('id', id);
						if (error) alert(error.message);
						else loadItems();
					}
				});
			});
		}

		function openModal(item = null) {
			if (item) {
				modalTitleEl!.innerHTML = 'Edit <span class="gold-text">Item</span>';
				submitBtn!.textContent = 'Update Item';
				(document.getElementById('item-id') as HTMLInputElement).value = item.id;
				(document.getElementById('title') as HTMLInputElement).value = item.title;
				(document.getElementById('description') as HTMLTextAreaElement).value = item.description || '';
				(document.getElementById('category') as HTMLSelectElement).value = item.category || 'feature';
				(document.getElementById('priority') as HTMLSelectElement).value = item.priority || 'medium';
				(document.getElementById('status') as HTMLSelectElement).value = item.status;
				(document.getElementById('assigned_to') as HTMLSelectElement).value = item.assigned_to || '';
			} else {
				modalTitleEl!.innerHTML = 'New <span class="gold-text">Item</span>';
				submitBtn!.textContent = 'Save Item';
				form.reset();
				(document.getElementById('item-id') as HTMLInputElement).value = '';
				(document.getElementById('priority') as HTMLSelectElement).value = 'medium';
			}
			modal?.classList.add('active');
		}

		function closeModal() {
			modal?.classList.remove('active');
		}

		openModalBtn?.addEventListener('click', () => openModal());
		cancelBtn?.addEventListener('click', closeModal);

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const id = formData.get('id') as string;
			const { data: { session } } = await supabase.auth.getSession();

			const payload = {
				title: formData.get('title'),
				description: formData.get('description'),
				category: formData.get('category'),
				priority: formData.get('priority'),
				status: formData.get('status'),
				assigned_to: formData.get('assigned_to') || null,
			};

