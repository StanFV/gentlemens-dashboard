---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Backlog | Gentlemen's Dashboard">
	<header class="page-header">
		<div>
			<h1 class="serif">Product <span class="gold-text italic">Backlog</span></h1>
			<p class="subtitle">Manage features and bugs. Prioritize what matters.</p>
		</div>
		<button id="open-modal-btn" class="btn-primary">+ Add Item</button>
	</header>

	<div class="list-filters card">
		<div class="filters-top">
			<div class="search-wrap">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
				<input type="text" id="backlog-search" placeholder="Search backlog..." />
			</div>
			<div class="filters-top-right">
				<div class="filter-group">
					<button class="filter-btn active" data-status="all">All</button>
					<button class="filter-btn" data-status="planned">Planned</button>
					<button class="filter-btn" data-status="in-progress">In Progress</button>
					<button class="filter-btn" data-status="completed">Completed</button>
				</div>
				<button class="filters-toggle-btn" id="filters-toggle-btn">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="8" x2="16" y1="12" y2="12"/><line x1="12" x2="12" y1="18" y2="18"/></svg>
					Filters
					<span id="filter-badge" class="filter-badge hidden">0</span>
				</button>
			</div>
		</div>
		<div class="filters-panel" id="filters-panel">
			<div class="filters-panel-inner">
				<div class="filter-row">
					<div class="filter-control">
						<label class="filter-label">Sorteer</label>
						<div class="sort-group">
							<button class="sort-btn active" data-sort="date">Datum</button>
							<button class="sort-btn" data-sort="priority">Prioriteit</button>
							<button class="sort-btn" data-sort="category">Categorie</button>
						</div>
					</div>
					<div class="filter-control">
						<label class="filter-label">Lid</label>
						<select id="filter-person" class="filter-select">
							<option value="">Iedereen</option>
						</select>
					</div>
					<div class="filter-control">
						<label class="filter-label">Periode</label>
						<select id="filter-period" class="filter-select">
							<option value="">Alle tijd</option>
							<option value="week">Deze week</option>
							<option value="month">Deze maand</option>
							<option value="year">Dit jaar</option>
						</select>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="list-wrapper card">
		<div class="list-header">
			<div class="col-status">Status</div>
			<div class="col-priority">Priority</div>
			<div class="col-title">Item</div>
			<div class="col-assignee">Assigned To</div>
			<div class="col-date">Date</div>
			<div class="col-actions"></div>
		</div>
		<div id="backlog-container" class="list-items">
			<div class="loading-state">Loading the backlog...</div>
		</div>
	</div>

	<!-- Backlog Item Modal -->
	<div id="backlog-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="modal-title" class="serif">New <span class="gold-text">Item</span></h2>
			<form id="backlog-form">
				<input type="hidden" id="item-id" name="id" />
				<div class="form-group">
					<label for="title">Title *</label>
					<input type="text" id="title" name="title" required placeholder="A brief, descriptive title" />
				</div>
				<div class="form-group">
					<label for="description">Description</label>
					<textarea id="description" name="description" rows="3" placeholder="Elaborate on the item..."></textarea>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="category">Category</label>
						<select id="category" name="category">
							<option value="feature">Feature</option>
							<option value="bug">Bug</option>
						</select>
					</div>
					<div class="form-group">
						<label for="priority">Priority</label>
						<select id="priority" name="priority">
							<option value="high">High</option>
							<option value="medium" selected>Medium</option>
							<option value="low">Low</option>
						</select>
					</div>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="status">Status</label>
						<select id="status" name="status">
							<option value="planned">Planned</option>
							<option value="in-progress">In Progress</option>
							<option value="completed">Completed</option>
						</select>
					</div>
					<div class="form-group">
						<label for="assigned_to">Assignee</label>
						<select id="assigned_to" name="assigned_to">
							<option value="">Unassigned</option>
						</select>
					</div>
				</div>
				<div class="modal-actions">
					<button type="button" id="cancel-btn" class="btn-secondary">Cancel</button>
					<button type="submit" id="submit-btn" class="btn-primary">Save Item</button>
				</div>
			</form>
		</div>
	</div>

	<!-- Hours Modal (feature) -->
	<div id="hours-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="hours-modal-title" class="serif">Log Hours</h2>
			<div class="form-group">
				<label>Datum</label>
				<input type="date" id="hours-date" style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:.75rem 1rem;color:var(--color-text);outline:none;" />
			</div>
			<div class="form-group">
				<label>Omschrijving</label>
				<input type="text" id="hours-desc" placeholder="Wat is er gedaan?" style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:.75rem 1rem;color:var(--color-text);font-family:inherit;outline:none;" />
			</div>
			<div id="persons-rows" class="persons-rows"></div>
			<button type="button" id="add-person-btn" class="add-person-btn">+ Persoon toevoegen</button>
			<div class="modal-actions">
				<button type="button" id="hours-cancel-btn" class="btn-secondary">Annuleren</button>
				<button type="button" id="hours-submit-btn" class="btn-primary">Uren Opslaan</button>
			</div>
		</div>
	</div>

	<!-- Feature Hours Drawer -->
	<div id="drawer-overlay" class="drawer-overlay"></div>
	<div id="feature-hours-drawer" class="hours-drawer">
		<div class="drawer-inner card">
			<div class="drawer-header">
				<h3 id="drawer-feature-title" class="serif"></h3>
				<button id="drawer-close-btn" class="btn-icon" style="font-size:1.2rem;width:32px;height:32px;">×</button>
			</div>
			<div id="drawer-body" class="drawer-body"></div>
		</div>
	</div>

	<script>
		import { supabase } from '../lib/supabase';

		const container = document.getElementById('backlog-container');
		const filterBtns = document.querySelectorAll('.filter-btn');
		const sortBtns = document.querySelectorAll('.sort-btn');
		const modal = document.getElementById('backlog-modal');
		const openModalBtn = document.getElementById('open-modal-btn');
		const cancelBtn = document.getElementById('cancel-btn');
		const form = document.getElementById('backlog-form') as HTMLFormElement;
		const userSelect = document.getElementById('assigned_to') as HTMLSelectElement;
		const filterPersonSelect = document.getElementById('filter-person') as HTMLSelectElement;
		const filterPeriodSelect = document.getElementById('filter-period') as HTMLSelectElement;
		const searchInput = document.getElementById('backlog-search') as HTMLInputElement;
		const modalTitleEl = document.getElementById('modal-title');
		const submitBtn = document.getElementById('submit-btn');
		const filtersToggleBtn = document.getElementById('filters-toggle-btn');
		const filtersPanel = document.getElementById('filters-panel');
		const filterBadge = document.getElementById('filter-badge');

		let currentStatus = 'all';
		let currentSort = 'date';
		let searchQuery = '';
		let personFilter = '';
		let periodFilter = '';
		let cachedItems: any[] = [];
		let hoursMap: Record<string, number> = {};
		let profiles: any[] = [];
		let hoursModalFeatureId: string | null = null;
		let drawerFeatureId: string | null = null;

		const PRIORITY_ORDER: Record<string, number> = { high: 0, medium: 1, low: 2 };

		// Collapsible filter panel
		let filtersOpen = false;
		filtersToggleBtn?.addEventListener('click', () => {
			filtersOpen = !filtersOpen;
			filtersPanel?.classList.toggle('open', filtersOpen);
			filtersToggleBtn.classList.toggle('active', filtersOpen);
		});

		function updateFilterBadge() {
			let count = 0;
			if (personFilter) count++;
			if (periodFilter) count++;
			if (currentSort !== 'date') count++;
			if (count > 0) {
				filterBadge?.classList.remove('hidden');
				filterBadge!.textContent = String(count);
			} else {
				filterBadge?.classList.add('hidden');
			}
		}

		searchInput?.addEventListener('input', () => {
			searchQuery = searchInput.value.toLowerCase();
			renderItems(getFilteredItems());
		});

		filterPersonSelect?.addEventListener('change', () => {
			personFilter = filterPersonSelect.value;
			updateFilterBadge();
			renderItems(getFilteredItems());
		});

		filterPeriodSelect?.addEventListener('change', () => {
			periodFilter = filterPeriodSelect.value;
			updateFilterBadge();
			renderItems(getFilteredItems());
		});

		function getFilteredItems() {
			let items = cachedItems.filter(f => {
				if (searchQuery && !(
					(f.title || '').toLowerCase().includes(searchQuery) ||
					(f.description || '').toLowerCase().includes(searchQuery)
				)) return false;
				if (personFilter && f.assigned_to !== personFilter) return false;
				if (periodFilter) {
					const created = new Date(f.created_at);
					const now = new Date();
					if (periodFilter === 'week') {
						const weekAgo = new Date(now); weekAgo.setDate(now.getDate() - 7);
						if (created < weekAgo) return false;
					} else if (periodFilter === 'month') {
						const monthAgo = new Date(now); monthAgo.setMonth(now.getMonth() - 1);
						if (created < monthAgo) return false;
					} else if (periodFilter === 'year') {
						const yearAgo = new Date(now); yearAgo.setFullYear(now.getFullYear() - 1);
						if (created < yearAgo) return false;
					}
				}
				return true;
			});
			return sortItems(items);
		}

		function priorityIcon(p: string) {
			if (p === 'high') return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>`;
			if (p === 'low') return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>`;
			return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>`;
		}

		function sortItems(items: any[]) {
			const sorted = [...items];
			if (currentSort === 'priority') {
				sorted.sort((a, b) => (PRIORITY_ORDER[a.priority] ?? 1) - (PRIORITY_ORDER[b.priority] ?? 1));
			} else if (currentSort === 'category') {
				sorted.sort((a, b) => (a.category ?? '').localeCompare(b.category ?? ''));
			} else {
				sorted.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
			}
			return sorted;
		}

		async function loadUsers() {
			const { data } = await supabase.from('profiles').select('id, full_name, username');
			profiles = data || [];
			if (data) {
				data.forEach(profile => {
					const name = profile.full_name || profile.username;
					const opt1 = document.createElement('option');
					opt1.value = profile.id; opt1.textContent = name;
					userSelect.appendChild(opt1);
					const opt2 = document.createElement('option');
					opt2.value = profile.id; opt2.textContent = name;
					filterPersonSelect?.appendChild(opt2);
				});
			}
		}

		async function loadHoursMap(itemIds: string[]) {
			if (!itemIds.length) return;
			const { data } = await supabase
				.from('time_entries')
				.select('feature_id, hours')
				.in('feature_id', itemIds);
			hoursMap = {};
			(data || []).forEach((e: any) => {
				hoursMap[e.feature_id] = (hoursMap[e.feature_id] || 0) + (e.hours || 0);
			});
		}

		async function loadItems() {
			if (!container) return;
			container.innerHTML = '<div class="loading-state">Loading the backlog...</div>';

			let query = supabase
				.from('feature_requests')
				.select(`*, assignee:profiles!assigned_to(full_name, username, avatar_url)`);

			if (currentStatus !== 'all') query = query.eq('status', currentStatus);

			const { data, error } = await query;

			if (error) {
				container.innerHTML = `<div class="empty-state"><p>Error: ${error.message}</p></div>`;
				return;
			}

			if (!data || data.length === 0) {
				container.innerHTML = `<div class="empty-state"><p>The backlog is clear.</p></div>`;
				return;
			}

			cachedItems = data;
			await loadHoursMap(data.map(f => f.id));
			renderItems(getFilteredItems());
		}

		function renderItems(items: any[]) {
			if (!container) return;
			if (items.length === 0) {
				container.innerHTML = `<div class="empty-state"><p>No items match your filters.</p></div>`;
				return;
			}
			container.innerHTML = items.map(f => {
				const assignee = f.assignee;
				const assigneeName = assignee ? (assignee.full_name || assignee.username) : 'Unassigned';
				const assigneeAvatar = assignee?.avatar_url || `https://ui-avatars.com/api/?name=${assigneeName}&background=1c1917&color=c5a059`;
				const category = f.category || 'feature';
				const priority = f.priority || 'medium';
				const hours = hoursMap[f.id] || 0;

				return `
					<div class="list-item" data-id="${f.id}">
						<div class="col-status">
							<span class="status-badge status-${f.status}">${f.status}</span>
						</div>
						<div class="col-priority">
							<span class="priority-badge priority-${priority}">
								${priorityIcon(priority)}
								${priority}
							</span>
						</div>
						<div class="col-title">
							<div class="title-group">
								<div class="title-row">
									<h3 class="item-title">${f.title}</h3>
									<span class="category-badge category-${category}">${category}</span>
									<button class="hours-chip open-hours-drawer" title="Bekijk uren">
										<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
										${hours}h
									</button>
								</div>
								<p class="item-desc">${f.description || 'No description provided.'}</p>
							</div>
						</div>
						<div class="col-assignee">
							<div class="assignee-pill">
								<img src="${assigneeAvatar}" class="assignee-avatar" />
								<span>${assigneeName}</span>
							</div>
						</div>
						<div class="col-date">
							<span class="date">${new Date(f.created_at).toLocaleDateString()}</span>
						</div>
						<div class="col-actions">
							<button class="btn-icon edit-btn" title="Edit">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
							</button>
							<button class="btn-icon delete-btn" title="Delete">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
							</button>
						</div>
					</div>
				`;
			}).join('');

			setupActionButtons();
		}

		function setupActionButtons() {
			document.querySelectorAll('.edit-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					const item = cachedItems.find(f => f.id === id);
					if (item) openModal(item);
				});
			});

			document.querySelectorAll('.delete-btn').forEach(btn => {
				btn.addEventListener('click', async (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					if (id && confirm('Remove this item from the backlog?')) {
						const { error } = await supabase.from('feature_requests').delete().eq('id', id);
						if (error) alert(error.message);
						else loadItems();
					}
				});
			});

			document.querySelectorAll('.open-hours-drawer').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const item = (e.currentTarget as HTMLElement).closest('.list-item');
					const id = item?.getAttribute('data-id');
					const title = item?.querySelector('.item-title')?.textContent || '';
					if (id) openFeatureHoursDrawer(id, title);
				});
			});
		}

		function openModal(item: any = null) {
			if (item) {
				modalTitleEl!.innerHTML = 'Edit <span class="gold-text">Item</span>';
				submitBtn!.textContent = 'Update Item';
				(document.getElementById('item-id') as HTMLInputElement).value = item.id;
				(document.getElementById('title') as HTMLInputElement).value = item.title;
				(document.getElementById('description') as HTMLTextAreaElement).value = item.description || '';
				(document.getElementById('category') as HTMLSelectElement).value = item.category || 'feature';
				(document.getElementById('priority') as HTMLSelectElement).value = item.priority || 'medium';
				(document.getElementById('status') as HTMLSelectElement).value = item.status;
				(document.getElementById('assigned_to') as HTMLSelectElement).value = item.assigned_to || '';
			} else {
				modalTitleEl!.innerHTML = 'New <span class="gold-text">Item</span>';
				submitBtn!.textContent = 'Save Item';
				form.reset();
				(document.getElementById('item-id') as HTMLInputElement).value = '';
				(document.getElementById('priority') as HTMLSelectElement).value = 'medium';
			}
			modal?.classList.add('active');
		}

		function closeModal() { modal?.classList.remove('active'); }

		openModalBtn?.addEventListener('click', () => openModal());
		cancelBtn?.addEventListener('click', closeModal);

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const id = formData.get('id') as string;
			const { data: { session } } = await supabase.auth.getSession();

			const payload = {
				title: formData.get('title'),
				description: formData.get('description'),
				category: formData.get('category'),
				priority: formData.get('priority'),
				status: formData.get('status'),
				assigned_to: formData.get('assigned_to') || null,
			};

			let result;
			const oldItem = id ? cachedItems.find(f => f.id === id) : null;

			if (id) {
				result = await supabase.from('feature_requests').update(payload).eq('id', id);
				if (!result.error && oldItem && oldItem.status !== payload.status) {
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_status_changed',
						title: 'Backlog Item Status Updated',
						content: `Status of "${payload.title}" changed from ${oldItem.status} to ${payload.status}`,
						link: '/backlog'
					});
				} else if (!result.error) {
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_updated',
						title: 'Backlog Item Updated',
						content: `"${payload.title}" was updated.`,
						link: '/backlog'
					});
				}
			} else {
				result = await supabase.from('feature_requests').insert({ ...payload, user_id: session?.user.id });
				if (!result.error) {
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_added',
						title: 'New Backlog Item',
						content: `"${payload.title}" was added to the backlog.`,
						link: '/backlog'
					});
				}
			}

			if (result.error) alert(result.error.message);
			else { closeModal(); loadItems(); }
		});

		filterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				filterBtns.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				currentStatus = (btn as HTMLButtonElement).dataset.status || 'all';
				loadItems();
			});
		});

		sortBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				sortBtns.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				currentSort = (btn as HTMLButtonElement).dataset.sort || 'date';
				updateFilterBadge();
				renderItems(getFilteredItems());
			});
		});

		// Feature Hours Drawer
		async function openFeatureHoursDrawer(featureId: string, featureTitle: string) {
			drawerFeatureId = featureId;
			const drawer = document.getElementById('feature-hours-drawer');
			const overlay = document.getElementById('drawer-overlay');
			const drawerTitleEl = document.getElementById('drawer-feature-title');
			const drawerBody = document.getElementById('drawer-body');

			if (drawerTitleEl) drawerTitleEl.textContent = featureTitle;
			if (drawerBody) drawerBody.innerHTML = '<p style="color:var(--color-text-muted);font-style:italic;padding:1rem 0">Loading...</p>';
			drawer?.classList.add('active');
			overlay?.classList.add('active');

			const { data: entries, error } = await supabase
				.from('time_entries')
				.select('*, profiles!time_entries_profile_fkey(full_name, username, avatar_url)')
				.eq('feature_id', featureId)
				.order('date', { ascending: false });

			if (error || !entries) {
				if (drawerBody) drawerBody.innerHTML = `<p style="color:var(--color-text-muted)">Error loading hours.</p>`;
				return;
			}

			const total = entries.reduce((sum: number, e: any) => sum + (e.hours || 0), 0);

			const personMap: Record<string, { name: string; avatar: string; hours: number }> = {};
			for (const e of entries) {
				const profile = e.profiles;
				const name = profile?.full_name || profile?.username || 'Unknown';
				const avatar = profile?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=1c1917&color=c5a059`;
				if (!personMap[name]) personMap[name] = { name, avatar, hours: 0 };
				personMap[name].hours += e.hours || 0;
			}
			const persons = Object.values(personMap).sort((a, b) => b.hours - a.hours);
			const maxHours = persons[0]?.hours || 1;

			const personsHTML = persons.map(p => `
				<div class="drawer-person">
					<img src="${p.avatar}" class="drawer-avatar" />
					<div class="drawer-person-info">
						<span class="drawer-person-name">${p.name}</span>
						<div class="drawer-bar-wrap">
							<div class="drawer-bar" style="width:${Math.round((p.hours / maxHours) * 100)}%"></div>
						</div>
					</div>
					<span class="drawer-person-hours">${p.hours}h</span>
				</div>
			`).join('');

			const timelineHTML = entries.map((e: any) => {
				const profile = e.profiles;
				const name = profile?.full_name || profile?.username || 'Unknown';
				return `
					<div class="drawer-entry">
						<span class="drawer-entry-date">${e.date || ''}</span>
						<span class="drawer-entry-name">${name}</span>
						<span class="drawer-entry-hours">${e.hours}h</span>
						${e.description ? `<span class="drawer-entry-desc">${e.description}</span>` : ''}
					</div>
				`;
			}).join('');

			if (drawerBody) drawerBody.innerHTML = `
				<div class="drawer-total">
					<span class="drawer-total-label">Total Hours</span>
					<span class="drawer-total-value">${total}h</span>
				</div>
				${persons.length > 0 ? `
					<p class="drawer-section-label">Per Person</p>
					<div class="drawer-persons">${personsHTML}</div>
				` : ''}
				${entries.length > 0 ? `
					<p class="drawer-section-label">Timeline</p>
					<div class="drawer-timeline">${timelineHTML}</div>
				` : '<p style="color:var(--color-text-muted);font-style:italic;margin-top:1rem">No hours logged yet.</p>'}
				<button class="drawer-log-btn btn-primary" id="drawer-log-hours-btn">+ Uren toevoegen</button>
			`;

			document.getElementById('drawer-log-hours-btn')?.addEventListener('click', () => {
				closeDrawer();
				const feature = cachedItems.find(f => f.id === featureId);
				openHoursModal(featureId, feature?.title || '');
			});
		}

		function closeDrawer() {
			document.getElementById('feature-hours-drawer')?.classList.remove('active');
			document.getElementById('drawer-overlay')?.classList.remove('active');
			drawerFeatureId = null;
		}

		document.getElementById('drawer-close-btn')?.addEventListener('click', closeDrawer);
		document.getElementById('drawer-overlay')?.addEventListener('click', closeDrawer);

		// Hours Modal
		function openHoursModal(featureId: string, featureTitle: string) {
			hoursModalFeatureId = featureId;
			const titleEl = document.getElementById('hours-modal-title');
			if (titleEl) titleEl.textContent = `Log Hours — ${featureTitle}`;
			const dateEl = document.getElementById('hours-date') as HTMLInputElement;
			if (dateEl) dateEl.value = new Date().toISOString().split('T')[0];
			const descEl = document.getElementById('hours-desc') as HTMLInputElement;
			if (descEl) descEl.value = '';
			resetPersonRows();
			document.getElementById('hours-modal')?.classList.add('active');
		}

		function closeHoursModal() {
			document.getElementById('hours-modal')?.classList.remove('active');
			hoursModalFeatureId = null;
		}

		document.getElementById('hours-cancel-btn')?.addEventListener('click', closeHoursModal);

		function buildPersonRow() {
			const opts = profiles.map(p => `<option value="${p.id}">${p.full_name || p.username}</option>`).join('');
			return `
				<div class="person-row">
					<select class="person-select form-ctrl-sel">${opts}</select>
					<input type="number" class="hours-input form-ctrl-num" placeholder="Uren" min="0.5" step="0.5" />
					<button type="button" class="remove-row-btn btn-icon" title="Remove">×</button>
				</div>
			`;
		}

		function resetPersonRows() {
			const rowsEl = document.getElementById('persons-rows');
			if (!rowsEl) return;
			rowsEl.innerHTML = buildPersonRow();
			setupRemoveBtns();
		}

		function setupRemoveBtns() {
			document.querySelectorAll('.remove-row-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const row = (e.currentTarget as HTMLElement).closest('.person-row');
					const rowsEl = document.getElementById('persons-rows');
					if (rowsEl && rowsEl.querySelectorAll('.person-row').length > 1) row?.remove();
				});
			});
		}

		document.getElementById('add-person-btn')?.addEventListener('click', () => {
			const rowsEl = document.getElementById('persons-rows');
			if (!rowsEl) return;
			const tmp = document.createElement('div');
			tmp.innerHTML = buildPersonRow();
			rowsEl.appendChild(tmp.firstElementChild!);
			setupRemoveBtns();
		});

		document.getElementById('hours-submit-btn')?.addEventListener('click', async () => {
			if (!hoursModalFeatureId) return;
			const rows = document.querySelectorAll('#persons-rows .person-row');
			const date = (document.getElementById('hours-date') as HTMLInputElement)?.value || new Date().toISOString().split('T')[0];
			const description = (document.getElementById('hours-desc') as HTMLInputElement)?.value || '';
			const { data: { session } } = await supabase.auth.getSession();

			const inserts: any[] = [];
			rows.forEach(row => {
				const userId = (row.querySelector('.person-select') as HTMLSelectElement)?.value;
				const hours = parseFloat((row.querySelector('.hours-input') as HTMLInputElement)?.value || '0');
				if (userId && hours > 0) {
					inserts.push({ user_id: userId, feature_id: hoursModalFeatureId, hours, date, description, logged_by: session?.user.id });
				}
			});

			if (inserts.length === 0) { alert('Voer minimaal één geldige invoer in.'); return; }
			const { error } = await supabase.from('time_entries').insert(inserts);
			if (error) alert(error.message);
			else {
				closeHoursModal();
				await supabase.from('notifications').insert({
					user_id: session?.user.id,
					type: 'hours_logged',
					title: 'Uren Geregistreerd',
					content: `${inserts.reduce((s: number, i: any) => s + i.hours, 0)} uren geregistreerd voor feature.`,
					link: '/backlog'
				});
				loadItems();
			}
		});

		loadUsers();
		loadItems();
	</script>
</AppLayout>

