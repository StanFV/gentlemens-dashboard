---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Settings | Gentlemen's Dashboard">
	<header class="settings-header">
		<h1 class="serif">Dashboard <span class="gold-text italic">Settings</span></h1>
		<p class="subtitle">System configurations.</p>
	</header>

	<div class="settings-grid">
		<!-- UI Section -->
		<section class="card settings-section">
			<h2 class="serif">Interface Preferences</h2>
			<div class="info-grid">
				<div class="setting-item">
					<div class="setting-info">
						<label>Always show sidebar</label>
						<p class="setting-desc">Keep the sidebar expanded on desktop instead of collapsing it.</p>
					</div>
					<label class="switch">
						<input type="checkbox" id="sidebar-toggle-checkbox">
						<span class="slider round"></span>
					</label>
				</div>
			</div>
		</section>

		<!-- Koos Alberts Easter Egg Section -->
		<section class="card settings-section">
			<h2 class="serif">Koos Alberts <span class="gold-text">Easter Egg</span></h2>
			<p class="setting-desc" style="margin-bottom:2rem">Beheer de foto en MP3-nummers voor de Koos Alberts easter egg. Trigger via het logo linksboven of typ "koosje" in de zoekbalk en druk op Enter.</p>

			<!-- Photo -->
			<div class="koos-sub">
				<div class="koos-sub-header">
					<h3 class="koos-sub-title">Foto</h3>
					<label class="btn-secondary koos-upload-label">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
						Foto uploaden
						<input type="file" id="koos-photo-input" accept="image/*" hidden />
					</label>
				</div>
				<div id="koos-photo-preview" class="koos-photo-preview">
					<p class="koos-empty">Geen foto geüpload.</p>
				</div>
			</div>

			<div class="koos-divider"></div>

			<!-- Songs -->
			<div class="koos-sub">
				<div class="koos-sub-header">
					<h3 class="koos-sub-title">Nummers <span id="koos-song-count" class="koos-count"></span></h3>
				</div>
				<div id="koos-songs-list" class="koos-songs-list">
					<p class="koos-empty">Geen nummers geüpload.</p>
				</div>
				<div class="koos-song-upload-form">
					<input type="text" id="koos-song-name-input" placeholder="Naam van het nummer (bijv. Geef mij maar Amsterdam)" class="koos-name-input" />
					<label class="btn-secondary koos-upload-label">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
						MP3 uploaden
						<input type="file" id="koos-song-input" accept="audio/mpeg,audio/mp3,.mp3" hidden />
					</label>
				</div>
				<div id="koos-upload-progress" class="koos-progress hidden">
					<div class="koos-progress-bar" id="koos-progress-bar"></div>
				</div>
			</div>
		</section>

		<!-- Supabase Section -->
		<section class="card settings-section">
			<h2 class="serif">Technical Infrastructure</h2>
			<div class="info-grid">
				<div class="info-group">
					<label>Supabase Project URL</label>
					<div class="url-display">
						<a href="https://supabase.com/dashboard/project/wcbngpinfdpzbewxbjaq" target="_blank" rel="noopener noreferrer">
							https://supabase.com/dashboard/project/wcbngpinfdpzbewxbjaq
						</a>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="external-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
					</div>
				</div>
				<div class="info-group">
					<label>GitHub Repository</label>
					<div class="url-display">
						<a href="https://github.com/StanFV/gentlemens-dashboard" target="_blank" rel="noopener noreferrer">
							https://github.com/StanFV/gentlemens-dashboard
						</a>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="external-icon"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
					</div>
				</div>
			</div>
		</section>
	</div>
</AppLayout>

<script>
	import { supabase } from '../lib/supabase';

	// Sidebar toggle
	const sidebarToggle = document.getElementById('sidebar-toggle-checkbox') as HTMLInputElement;
	if (sidebarToggle) {
		const alwaysShow = localStorage.getItem('sidebar-always-show') === 'true';
		sidebarToggle.checked = alwaysShow;
		sidebarToggle.addEventListener('change', () => {
			const isChecked = sidebarToggle.checked;
			localStorage.setItem('sidebar-always-show', isChecked ? 'true' : 'false');
			window.dispatchEvent(new CustomEvent('sidebar-toggle', { detail: { alwaysShow: isChecked } }));
		});
	}

	// Helpers
	function getPublicUrl(path: string) {
		return supabase.storage.from('koos-alberts').getPublicUrl(path).data.publicUrl;
	}

	// ---- Photo ----
	const photoPreview = document.getElementById('koos-photo-preview')!;
	const photoInput = document.getElementById('koos-photo-input') as HTMLInputElement;

	async function loadPhoto() {
		const { data } = await supabase.storage.from('koos-alberts').list('photo');
		if (data?.length) {
			const url = getPublicUrl('photo/' + data[0].name) + '?t=' + Date.now();
			photoPreview.innerHTML = `
				<div class="koos-photo-wrap">
					<img src="${url}" class="koos-current-photo" />
					<button class="koos-delete-photo btn-icon" data-name="${data[0].name}" title="Verwijder foto">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
					</button>
				</div>
			`;
			document.querySelector('.koos-delete-photo')?.addEventListener('click', async (e) => {
				const name = (e.currentTarget as HTMLElement).dataset.name!;
				await supabase.storage.from('koos-alberts').remove(['photo/' + name]);
				loadPhoto();
			});
		} else {
			photoPreview.innerHTML = '<p class="koos-empty">Geen foto geüpload.</p>';
		}
	}

	photoInput?.addEventListener('change', async () => {
		const file = photoInput.files?.[0];
		if (!file) return;

		// Remove old photos first
		const { data: existing } = await supabase.storage.from('koos-alberts').list('photo');
		if (existing?.length) {
			await supabase.storage.from('koos-alberts').remove(existing.map(f => 'photo/' + f.name));
		}

		const ext = file.name.split('.').pop();
		const { error } = await supabase.storage.from('koos-alberts').upload(`photo/koos-photo.${ext}`, file, { upsert: true });
		if (error) { alert('Upload mislukt: ' + error.message); return; }
		photoInput.value = '';
		loadPhoto();
	});

	// ---- Songs ----
	const songsList = document.getElementById('koos-songs-list')!;
	const songCount = document.getElementById('koos-song-count')!;
	const songInput = document.getElementById('koos-song-input') as HTMLInputElement;
	const songNameInput = document.getElementById('koos-song-name-input') as HTMLInputElement;
	const progressWrap = document.getElementById('koos-upload-progress')!;
	const progressBar = document.getElementById('koos-progress-bar')!;

	async function loadSongs() {
		const { data, error } = await supabase.from('koos_songs').select('*').order('created_at', { ascending: false });
		if (error || !data?.length) {
			songsList.innerHTML = '<p class="koos-empty">Geen nummers geüpload.</p>';
			songCount.textContent = '';
			return;
		}

		songCount.textContent = `(${data.length})`;
		songsList.innerHTML = data.map(song => `
			<div class="koos-song-row" data-id="${song.id}" data-path="${song.file_path}">
				<div class="koos-song-info">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="koos-note-icon"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
					<span class="koos-song-name">${song.display_name}</span>
				</div>
				<div class="koos-song-actions">
					<audio controls class="koos-preview-audio" src="${getPublicUrl(song.file_path)}"></audio>
					<button class="btn-icon koos-delete-song" title="Verwijder">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
					</button>
				</div>
			</div>
		`).join('');

		document.querySelectorAll('.koos-delete-song').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const row = (e.currentTarget as HTMLElement).closest('.koos-song-row') as HTMLElement;
				const id = row.dataset.id!;
				const path = row.dataset.path!;
				const name = row.querySelector('.koos-song-name')?.textContent || path;
				if (!confirm(`"${name}" verwijderen?`)) return;
				await supabase.storage.from('koos-alberts').remove([path]);
				const { error } = await supabase.from('koos_songs').delete().eq('id', id);
				if (error) alert(error.message);
				else loadSongs();
			});
		});
	}

	songInput?.addEventListener('change', async () => {
		const file = songInput.files?.[0];
		if (!file) return;

		const displayName = songNameInput?.value.trim() || file.name.replace(/\.[^/.]+$/, '');

		progressWrap.classList.remove('hidden');
		progressBar.style.width = '10%';

		const safeName = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9._-]/g, '_')}`;
		const filePath = `songs/${safeName}`;

		const { error: uploadError } = await supabase.storage.from('koos-alberts').upload(filePath, file);
		progressBar.style.width = '70%';

		if (uploadError) {
			alert('Upload mislukt: ' + uploadError.message);
			progressWrap.classList.add('hidden');
			return;
		}

		const { error: dbError } = await supabase.from('koos_songs').insert({ file_path: filePath, display_name: displayName });
		progressBar.style.width = '100%';
		setTimeout(() => progressWrap.classList.add('hidden'), 600);

		if (dbError) { alert('Opslaan mislukt: ' + dbError.message); return; }
		songInput.value = '';
		if (songNameInput) songNameInput.value = '';
		loadSongs();
	});

	// Initial load
	loadPhoto();
	loadSongs();
</script>

<style is:global>
	.settings-header { margin-bottom: 3rem; }
	.settings-header h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.settings-header .subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.settings-grid { display: flex; flex-direction: column; gap: 2rem; }
	.settings-section { padding: 2.5rem; }
	.settings-section h2 { font-size: 1.8rem; margin-bottom: 1rem; }

	.info-grid { display: flex; flex-direction: column; gap: 1.5rem; }
	.info-group label { display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 0.5rem; }

	.setting-item { display: flex; justify-content: space-between; align-items: center; padding: 1rem 0; }
	.setting-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; }

	.switch { position: relative; display: inline-block; width: 50px; height: 24px; }
	.switch input { opacity: 0; width: 0; height: 0; }
	.slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--color-border); transition: .4s; }
	.slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 4px; bottom: 4px; background-color: white; transition: .4s; }
	input:checked + .slider { background-color: var(--color-primary); }
	input:focus + .slider { box-shadow: 0 0 1px var(--color-primary); }
	input:checked + .slider:before { transform: translateX(26px); }
	.slider.round { border-radius: 24px; }
	.slider.round:before { border-radius: 50%; }

	.url-display { display: flex; align-items: center; justify-content: space-between; background: var(--color-surface); padding: 1rem 1.5rem; border-radius: 8px; border: 1px solid var(--color-border); min-width: 0; overflow: hidden; }
	.url-display a { color: var(--color-primary); text-decoration: none; font-family: monospace; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
	.url-display a:hover { text-decoration: underline; }
	.external-icon { color: var(--color-text-muted); flex-shrink: 0; margin-left: 0.75rem; }

	/* Koos Settings */
	.koos-sub { margin-top: 1.5rem; }
	.koos-sub-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
	.koos-sub-title { font-size: 1rem; font-weight: 600; color: var(--color-text); }
	.koos-count { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 400; margin-left: 0.4rem; }
	.koos-divider { height: 1px; background: var(--color-border); margin: 2rem 0; }
	.koos-empty { color: var(--color-text-muted); font-style: italic; font-size: 0.9rem; padding: 1rem 0; }

	.koos-upload-label { display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem; padding: 0.5rem 1rem; }

	.koos-song-upload-form { display: flex; gap: 0.75rem; align-items: center; margin-top: 0.75rem; flex-wrap: wrap; }
	.koos-name-input { flex: 1; min-width: 200px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; color: var(--color-text); font-size: 0.85rem; padding: 0.5rem 0.75rem; outline: none; }
	.koos-name-input:focus { border-color: var(--color-primary); }
	.koos-name-input::placeholder { color: var(--color-text-muted); }

	.koos-photo-preview { margin-top: 0.5rem; }
	.koos-photo-wrap { position: relative; display: inline-block; }
	.koos-current-photo { width: 160px; height: 200px; object-fit: cover; object-position: top; border-radius: 10px; border: 2px solid var(--color-primary); display: block; }
	.koos-delete-photo { position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(0,0,0,0.7); border-color: transparent; }
	.koos-delete-photo:hover { border-color: #fecaca; color: #fecaca; }

	.koos-songs-list { display: flex; flex-direction: column; gap: 0.5rem; }
	.koos-song-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; gap: 1rem; }
	.koos-song-info { display: flex; align-items: center; gap: 0.6rem; min-width: 0; }
	.koos-note-icon { color: var(--color-primary); flex-shrink: 0; }
	.koos-song-name { font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.koos-song-actions { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
	.koos-preview-audio { height: 28px; width: 180px; accent-color: var(--color-primary); }
	.koos-delete-song:hover { border-color: #fecaca; color: #fecaca; }

	.koos-progress { height: 3px; background: var(--color-border); border-radius: 100px; overflow: hidden; margin-top: 0.75rem; }
	.koos-progress.hidden { display: none; }
	.koos-progress-bar { height: 100%; background: var(--color-primary); border-radius: 100px; transition: width 0.3s ease; }

	.btn-icon { background: transparent; border: 1px solid var(--color-border); color: var(--color-text-muted); padding: 0.5rem; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
	.btn-icon:hover { border-color: var(--color-primary); color: var(--color-primary); }

	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }

	@media (max-width: 600px) {
		.koos-song-row { flex-direction: column; align-items: flex-start; }
		.koos-preview-audio { width: 100%; }
	}
</style>
