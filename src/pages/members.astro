---
import AppLayout from '../layouts/AppLayout.astro';
---

<script>
	import { supabase } from '../lib/supabase';

	async function loadUsers() {
		const userListEl = document.getElementById('user-list');
		if (!userListEl) return;

		const { data, error } = await supabase
			.from('profiles')
			.select('username, full_name, avatar_url')
			.order('username', { ascending: true });

		if (error) {
			console.error('Error fetching users:', error);
			userListEl.innerHTML = '<div class="error">Failed to fetch members.</div>';
			return;
		}

		if (data) {
			userListEl.innerHTML = data.map(user => `
				<div class="user-list-item">
					<img src="${user.avatar_url || `https://ui-avatars.com/api/?name=${user.username || 'User'}&background=1c1917&color=c5a059`}" class="user-list-avatar" />
					<div class="user-list-info">
						<p class="user-list-name">${user.full_name || 'Anonymous Gentleman'}</p>
						<p class="user-list-username">@${user.username || 'unknown'}</p>
					</div>
				</div>
			`).join('');
		}
	}

	loadUsers();
</script>

<AppLayout title="Members | Gentlemen's Dashboard">
	<header class="members-header">
		<h1 class="serif">Gentlemen's <span class="gold-text italic">Directory</span></h1>
		<p class="subtitle">A complete overview of all registered members.</p>
	</header>

	<div class="members-grid">
		<section class="card members-section">
			<h2 class="serif">Registered Members</h2>
			<div id="user-list" class="user-list">
				<div class="loading-state">Fetching member records...</div>
			</div>
		</section>
	</div>
</AppLayout>

<style is:global>
	.members-header { margin-bottom: 3rem; }
	.members-header h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.members-header .subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.members-grid { display: flex; flex-direction: column; gap: 2rem; }
	
	.members-section { padding: 2.5rem; }
	.members-section h2 { font-size: 1.8rem; margin-bottom: 2rem; }

	/* Member List Styles */
	.user-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--color-border);
	}

	.user-list-item {
		padding: 1rem 0;
		display: flex;
		align-items: center;
		gap: 1rem;
		border-bottom: 1px solid var(--color-border);
		transition: all 0.2s;
	}
	.user-list-item:last-child { border-bottom: none; }
	.user-list-item:hover .user-list-name { color: var(--color-primary); }

	.user-list-avatar {
		width: 32px !important;
		height: 32px !important;
		min-width: 32px;
		border-radius: 4px;
		border: 1px solid var(--color-border);
		object-fit: cover;
	}

	.user-list-info {
		display: flex;
		flex-direction: row;
		align-items: baseline;
		gap: 0.75rem;
		flex-grow: 1;
	}

	.user-list-name { font-size: 0.9rem; font-weight: 500; color: var(--color-text); transition: color 0.2s; }
	.user-list-username { font-size: 0.8rem; color: var(--color-text-muted); font-family: monospace; }

	.loading-state, .error { padding: 2rem; text-align: center; color: var(--color-text-muted); font-style: italic; font-size: 0.85rem; }
	
	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }
</style>