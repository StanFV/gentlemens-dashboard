---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Feature Backlog | Gentlemen's Dashboard">
	<header class="page-header">
		<div>
			<h1 class="serif">Feature <span class="gold-text italic">Backlog</span></h1>
			<p class="subtitle">Suggest, manage, and track upcoming dashboard refinements.</p>
		</div>
		<button id="open-modal-btn" class="btn-primary">+ Create New Request</button>
	</header>

	<div class="list-filters card">
		<div class="filter-group">
			<button class="filter-btn active" data-status="all">All</button>
			<button class="filter-btn" data-status="pending">Pending</button>
			<button class="filter-btn" data-status="planned">Planned</button>
			<button class="filter-btn" data-status="in-progress">In Progress</button>
			<button class="filter-btn" data-status="completed">Completed</button>
		</div>
	</div>

	<div class="list-wrapper card">
		<div class="list-header">
			<div class="col-status">Status</div>
			<div class="col-title">Feature Request</div>
			<div class="col-assignee">Assigned To</div>
			<div class="col-date">Date</div>
			<div class="col-actions"></div>
		</div>
		<div id="features-container" class="list-items">
			<div class="loading-state">Loading the request vault...</div>
		</div>
	</div>

	<!-- Modal -->
	<div id="feature-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="modal-title" class="serif">New <span class="gold-text">Request</span></h2>
			<form id="feature-form">
				<input type="hidden" id="feature-id" name="id" />
				<div class="form-group">
					<label for="title">Feature Title *</label>
					<input type="text" id="title" name="title" required placeholder="A brief, descriptive title" />
				</div>
				<div class="form-group">
					<label for="description">Detailed Description</label>
					<textarea id="description" name="description" rows="4" placeholder="Elaborate on the request..."></textarea>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="status">Current Status</label>
						<select id="status" name="status">
							<option value="planned">Planned</option>
							<option value="in-progress">In Progress</option>
							<option value="completed">Completed</option>
						</select>
					</div>
					<div class="form-group">
						<label for="assigned_to">Assignee</label>
						<select id="assigned_to" name="assigned_to">
							<option value="">Unassigned</option>
						</select>
					</div>
				</div>
				
				<div class="modal-actions">
					<button type="button" id="cancel-btn" class="btn-secondary">Cancel</button>
					<button type="submit" id="submit-btn" class="btn-primary">Save Request</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		import { supabase } from '../lib/supabase';

		const container = document.getElementById('features-container');
		const filterBtns = document.querySelectorAll('.filter-btn');
		const modal = document.getElementById('feature-modal');
		const openModalBtn = document.getElementById('open-modal-btn');
		const cancelBtn = document.getElementById('cancel-btn');
		const form = document.getElementById('feature-form') as HTMLFormElement;
		const userSelect = document.getElementById('assigned_to') as HTMLSelectElement;
		const modalTitleEl = document.getElementById('modal-title');
		const submitBtn = document.getElementById('submit-btn');

		let currentStatus = 'all';
		let cachedFeatures = [];

		async function loadUsers() {
			const { data } = await supabase.from('profiles').select('id, full_name, username');
			if (data) {
				data.forEach(profile => {
					const option = document.createElement('option');
					option.value = profile.id;
					option.textContent = profile.full_name || profile.username;
					userSelect.appendChild(option);
				});
			}
		}

		async function loadFeatures() {
			if (!container) return;
			container.innerHTML = '<div class="loading-state">Loading the request vault...</div>';

			let query = supabase
				.from('feature_requests')
				.select(`
					*,
					assignee:profiles!assigned_to (
						full_name,
						username,
						avatar_url
					)
				`)
				.order('created_at', { ascending: false });

			if (currentStatus !== 'all') {
				query = query.eq('status', currentStatus);
			}

			const { data, error } = await query;

			if (error) {
				container.innerHTML = `<div class="empty-state"><p>Error: ${error.message}</p></div>`;
				return;
			}

			if (!data || data.length === 0) {
				container.innerHTML = `<div class="empty-state"><p>No requests found in this archives.</p></div>`;
				return;
			}

			cachedFeatures = data;
			renderFeatures(data);
		}

		function renderFeatures(features) {
			container!.innerHTML = features.map(f => {
				const assignee = f.assignee;
				const assigneeName = assignee ? (assignee.full_name || assignee.username) : 'Unassigned';
				const assigneeAvatar = assignee?.avatar_url || `https://ui-avatars.com/api/?name=${assigneeName}&background=1c1917&color=c5a059`;

				return `
					<div class="list-item" data-id="${f.id}">
						<div class="col-status">
							<span class="status-badge status-${f.status}">${f.status}</span>
						</div>
						<div class="col-title">
							<div class="title-group">
								<h3 class="item-title">${f.title}</h3>
								<p class="item-desc">${f.description || 'No description provided.'}</p>
							</div>
						</div>
						<div class="col-assignee">
							<div class="assignee-pill">
								<img src="${assigneeAvatar}" class="assignee-avatar" />
								<span>${assigneeName}</span>
							</div>
						</div>
						<div class="col-date">
							<span class="date">${new Date(f.created_at).toLocaleDateString()}</span>
						</div>
						<div class="col-actions">
							<button class="btn-icon edit-btn" title="Edit">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
							</button>
							<button class="btn-icon delete-btn" title="Delete">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
							</button>
						</div>
					</div>
				`;
			}).join('');

			setupActionButtons();
		}

		function setupActionButtons() {
			document.querySelectorAll('.edit-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					const feature = cachedFeatures.find(f => f.id === id);
					if (feature) openModal(feature);
				});
			});

			document.querySelectorAll('.delete-btn').forEach(btn => {
				btn.addEventListener('click', async (e) => {
					const id = (e.currentTarget as HTMLElement).closest('.list-item')?.getAttribute('data-id');
					if (id && confirm('Are you certain you wish to purge this request?')) {
						const { error } = await supabase.from('feature_requests').delete().eq('id', id);
						if (error) alert(error.message);
						else loadFeatures();
					}
				});
			});
		}

		function openModal(feature = null) {
			if (feature) {
				modalTitleEl!.innerHTML = 'Edit <span class="gold-text">Request</span>';
				submitBtn!.textContent = 'Update Request';
				(document.getElementById('feature-id') as HTMLInputElement).value = feature.id;
				(document.getElementById('title') as HTMLInputElement).value = feature.title;
				(document.getElementById('description') as HTMLTextAreaElement).value = feature.description || '';
				(document.getElementById('status') as HTMLSelectElement).value = feature.status;
				(document.getElementById('assigned_to') as HTMLSelectElement).value = feature.assigned_to || '';
			} else {
				modalTitleEl!.innerHTML = 'New <span class="gold-text">Request</span>';
				submitBtn!.textContent = 'Save Request';
				form.reset();
				(document.getElementById('feature-id') as HTMLInputElement).value = '';
			}
			modal?.classList.add('active');
		}

		function closeModal() {
			modal?.classList.remove('active');
		}

		openModalBtn?.addEventListener('click', () => openModal());
		cancelBtn?.addEventListener('click', closeModal);

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const id = formData.get('id') as string;
			const { data: { session } } = await supabase.auth.getSession();

			const payload = {
				title: formData.get('title'),
				description: formData.get('description'),
				status: formData.get('status'),
				assigned_to: formData.get('assigned_to') || null,
			};

			let result;
			let oldFeature = id ? cachedFeatures.find(f => f.id === id) : null;

			if (id) {
				result = await supabase.from('feature_requests').update(payload).eq('id', id);
				
				if (!result.error && oldFeature && oldFeature.status !== payload.status) {
					// Notify status change
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_status_changed',
						title: 'Feature Status Updated',
						content: `Status of "${payload.title}" changed from ${oldFeature.status} to ${payload.status}`,
						link: '/feature-backlog'
					});
				} else if (!result.error) {
					// General update notification (optional, maybe only for major changes)
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_updated',
						title: 'Feature Request Updated',
						content: `"${payload.title}" was updated.`,
						link: '/feature-backlog'
					});
				}
			} else {
				result = await supabase.from('feature_requests').insert({ ...payload, user_id: session?.user.id });
				
				if (!result.error) {
					// Notify new feature
					await supabase.from('notifications').insert({
						user_id: session?.user.id,
						type: 'feature_added',
						title: 'New Feature Requested',
						content: `A new feature "${payload.title}" has been proposed.`,
						link: '/feature-backlog'
					});
				}
			}

			if (result.error) alert(result.error.message);
			else {
				closeModal();
				loadFeatures();
			}
		});

		filterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				filterBtns.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				currentStatus = (btn as HTMLButtonElement).dataset.status || 'all';
				loadFeatures();
			});
		});

		loadUsers();
		loadFeatures();
	</script>
</AppLayout>

<style is:global>
	.page-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
	h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.list-filters { padding: 1rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
	.filter-group { display: flex; gap: 0.5rem; }
	.filter-btn { background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-muted); padding: 0.5rem 1.25rem; border-radius: 100px; font-size: 0.85rem; cursor: pointer; transition: all 0.3s; }
	.filter-btn:hover { border-color: var(--color-primary); color: var(--color-text); }
	.filter-btn.active { background: var(--color-primary); color: var(--color-bg); border-color: var(--color-primary); }

	.list-wrapper { overflow: hidden; }
	.list-header { display: grid; grid-template-columns: 140px 1fr 180px 120px 100px; padding: 1.5rem 2rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); font-weight: 700; }
	
	.list-items { min-height: 200px; }
	.list-item { display: grid; grid-template-columns: 140px 1fr 180px 120px 100px; padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); align-items: center; transition: background 0.2s; }
	.list-item:last-child { border-bottom: none; }
	.list-item:hover { background: rgba(197, 160, 89, 0.03); }

	.col-title { padding-right: 2rem; }
	.item-title { font-size: 1.1rem; margin-bottom: 0.25rem; color: var(--color-text); }
	.item-desc { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.5; }

	.assignee-pill { display: flex; align-items: center; gap: 0.75rem; font-size: 0.85rem; font-weight: 500; }
	.assignee-avatar { width: 28px; height: 28px; border-radius: 6px; border: 1px solid var(--color-primary); }

	.date { font-size: 0.85rem; color: var(--color-text-muted); }

	.col-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
	.btn-icon { background: transparent; border: 1px solid var(--color-border); color: var(--color-text-muted); padding: 0.5rem; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
	.btn-icon:hover { border-color: var(--color-primary); color: var(--color-primary); }
	.delete-btn:hover { border-color: #fecaca; color: #fecaca; }

	.status-badge { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; padding: 0.25rem 0.75rem; border-radius: 100px; display: inline-block; }
	.status-pending { background: #4b5563; color: white; }
	.status-planned { background: #2563eb; color: white; }
	.status-in-progress { background: #d97706; color: white; }
	.status-completed { background: #059669; color: white; }

	.loading-state, .empty-state { padding: 4rem; text-align: center; color: var(--color-text-muted); font-style: italic; }

	/* Modal Styling - Shared with Projects */
	.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 1000; padding: 2rem; }
	.modal-overlay.active { display: flex; }
	.modal-card { width: 100%; max-width: 500px; padding: 3rem; }
	
	.form-group { margin-bottom: 1.5rem; }
	.form-group label { display: block; font-size: 0.65rem; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem; letter-spacing: 0.1em; font-weight: 700; }
	.form-group input, .form-group textarea, .form-group select { width: 100%; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.75rem 1rem; color: var(--color-text); font-family: inherit; outline: none; transition: border-color 0.2s; }
	.form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--color-primary); }
	
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
	.modal-actions { display: flex; gap: 1rem; margin-top: 2rem; }

	@media (max-width: 900px) {
		.list-header { display: none; }
		.list-item { grid-template-columns: 1fr; gap: 1rem; padding: 2rem; }
		.col-actions { justify-content: flex-start; }
		.col-status, .col-title, .col-assignee, .col-date, .col-actions { padding: 0; }
	}
</style>
