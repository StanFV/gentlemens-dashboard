---
import AppLayout from '../layouts/AppLayout.astro';
---

<script>
	import { supabase } from '../lib/supabase';

	// State
	let editingProjectId: string | null = null;
	let allProjects: any[] = [];
	let searchQuery = '';
	let drawerProjectId = '';

	// UI Elements
	const createBtn = document.getElementById('create-project-btn');
	const projectModal = document.getElementById('project-modal');
	const modalTitle = document.getElementById('modal-title');
	const submitBtn = document.getElementById('submit-btn');
	const cancelBtn = document.getElementById('cancel-btn');
	const projectForm = document.getElementById('project-form') as HTMLFormElement;
	const container = document.getElementById('projects-container');
	const searchInput = document.getElementById('project-search') as HTMLInputElement;
	const hoursDrawer = document.getElementById('project-hours-drawer')!;
	const drawerOverlay = document.getElementById('drawer-overlay')!;

	// Search
	searchInput?.addEventListener('input', () => {
		searchQuery = searchInput.value.toLowerCase();
		renderProjects();
	});

	// Toggle Modal
	function openModal(editId: string | null = null) {
		editingProjectId = editId;
		if (editId) {
			modalTitle!.innerHTML = 'Edit <span class="gold-text">Project</span>';
			submitBtn!.textContent = 'Update Project';
			loadProjectIntoForm(editId);
		} else {
			modalTitle!.innerHTML = 'New <span class="gold-text">Project</span>';
			submitBtn!.textContent = 'Initiate Project';
			projectForm.reset();
		}
		projectModal?.classList.add('active');
	}

	function closeModal() {
		projectModal?.classList.remove('active');
		editingProjectId = null;
		projectForm.reset();
	}

	createBtn?.addEventListener('click', () => openModal());
	cancelBtn?.addEventListener('click', closeModal);

	async function loadProjectIntoForm(id: string) {
		const { data, error } = await supabase.from('projects').select('*').eq('id', id).single();
		if (data) {
			(document.getElementById('title') as HTMLInputElement).value = data.title;
			(document.getElementById('client') as HTMLInputElement).value = data.client || '';
			(document.getElementById('start_date') as HTMLInputElement).value = data.start_date || '';
			(document.getElementById('end_date') as HTMLInputElement).value = data.end_date || '';
			(document.getElementById('files_url') as HTMLInputElement).value = data.files_url || '';
		}
	}

	// Fetch and Render Projects
	async function loadProjects() {
		const { data: projects, error } = await supabase
			.from('projects')
			.select('*')
			.order('created_at', { ascending: false });

		if (!container) return;

		if (error) {
			container.innerHTML = `<div class="empty-state card"><p>Error: ${error.message}</p></div>`;
			return;
		}

		if (!projects || projects.length === 0) {
			container.innerHTML = `<div class="empty-state card"><p>No projects found. Time to start something grand.</p></div>`;
			return;
		}

		allProjects = projects;
		renderProjects();
	}

	function renderProjects() {
		if (!container) return;

		const filtered = searchQuery
			? allProjects.filter(p =>
				p.title.toLowerCase().includes(searchQuery) ||
				(p.client || '').toLowerCase().includes(searchQuery)
			)
			: allProjects;

		if (filtered.length === 0) {
			container.innerHTML = `<div class="empty-state card"><p>Geen projecten gevonden voor "${searchInput.value}".</p></div>`;
			return;
		}

		container.innerHTML = filtered.map(project => `
			<div class="project-card card" data-id="${project.id}">
				<div class="p-header">
					<div class="p-main-info">
						<span class="p-category">${project.category || 'General'}</span>
						<h2 class="serif">${project.title}</h2>
						<p class="p-client">Client: <span>${project.client || 'Internal'}</span></p>
					</div>
					<div class="p-actions">
						<button class="btn-icon view-hours-project" title="Bekijk uren" data-id="${project.id}" data-title="${project.title}">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
						</button>
						<button class="btn-icon log-hours-project" title="Log hours" data-id="${project.id}" data-title="${project.title}">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
						</button>
						<button class="btn-icon edit-project" title="Edit">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
						</button>
						<button class="btn-icon delete-project" title="Delete">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
						</button>
					</div>
				</div>

				<div class="p-dates">
					<div class="date-item">
						<label>Started</label>
						<span>${project.start_date || 'TBD'}</span>
					</div>
					<div class="date-item">
						<label>Deadline</label>
						<span>${project.end_date || 'None'}</span>
					</div>
				</div>

				<div class="p-footer">
					${project.files_url ? `
						<a href="${project.files_url}" target="_blank" class="btn-secondary files-link">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><polyline points="14 2 14 8 20 8"/></svg>
							Files
						</a>
					` : `<span class="no-files">No files</span>`}
					<div class="p-progress-mini">
						<div class="p-bar-mini"><div class="p-fill-mini" style="width: ${project.progress}%"></div></div>
						<span class="p-num-mini">${project.progress}%</span>
					</div>
				</div>
			</div>
		`).join('');

		setupActionButtons();
	}

	// ── Hours Drawer ──────────────────────────────────────────────────────────
	function closeDrawer() {
		hoursDrawer.classList.remove('active');
		drawerOverlay.classList.remove('active');
	}

	drawerOverlay.addEventListener('click', closeDrawer);
	document.getElementById('close-drawer-btn')?.addEventListener('click', closeDrawer);

	async function openProjectHoursDrawer(projectId: string, projectTitle: string) {
		drawerProjectId = projectId;
		document.getElementById('drawer-project-title')!.textContent = projectTitle;
		document.getElementById('drawer-body')!.innerHTML = '<div class="drawer-loading">Uren laden...</div>';
		drawerOverlay.classList.add('active');
		hoursDrawer.classList.add('active');

		const { data, error } = await supabase
			.from('time_entries')
			.select('*, profile:profiles!time_entries_profile_fkey(full_name, username, avatar_url)')
			.eq('project_id', projectId)
			.order('date', { ascending: false });

		if (error || !data || data.length === 0) {
			document.getElementById('drawer-body')!.innerHTML = '<div class="drawer-empty">Nog geen uren geregistreerd voor dit project.</div>';
			return;
		}

		const total = data.reduce((sum, e) => sum + Number(e.hours), 0);
		const byPerson: Record<string, { name: string; hours: number; avatar: string }> = {};
		for (const e of data) {
			const uid = e.user_id;
			const name = e.profile?.full_name || e.profile?.username || 'Onbekend';
			const avatar = e.profile?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=1c1917&color=c5a059`;
			if (!byPerson[uid]) byPerson[uid] = { name, hours: 0, avatar };
			byPerson[uid].hours += Number(e.hours);
		}

		const personsSorted = Object.values(byPerson).sort((a, b) => b.hours - a.hours);
		const maxHours = personsSorted[0]?.hours || 1;

		const fmt = (h: number) => h % 1 === 0 ? String(h) : h.toFixed(1);

		document.getElementById('drawer-body')!.innerHTML = `
			<div class="drawer-total">
				<span class="drawer-total-num">${fmt(total)}</span>
				<span class="drawer-total-label">uur totaal</span>
			</div>

			<div class="drawer-section-label">Per persoon</div>
			<div class="drawer-persons">
				${personsSorted.map(p => `
					<div class="drawer-person">
						<img src="${p.avatar}" class="drawer-avatar" />
						<div class="drawer-person-info">
							<div class="drawer-person-top">
								<span class="drawer-person-name">${p.name}</span>
								<span class="drawer-person-hours">${fmt(p.hours)}u</span>
							</div>
							<div class="drawer-bar-wrap">
								<div class="drawer-bar" style="width: ${(p.hours / maxHours * 100).toFixed(1)}%"></div>
							</div>
						</div>
					</div>
				`).join('')}
			</div>

			<div class="drawer-section-label">Tijdlijn</div>
			<div class="drawer-timeline">
				${data.map(e => {
					const name = e.profile?.full_name || e.profile?.username || 'Onbekend';
					const avatar = e.profile?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=1c1917&color=c5a059`;
					const dateStr = new Date(e.date).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
					return `
						<div class="drawer-entry">
							<img src="${avatar}" class="drawer-avatar" />
							<div class="drawer-entry-info">
								<div class="drawer-entry-header">
									<span class="drawer-entry-name">${name}</span>
									<span class="drawer-entry-hrs">${fmt(Number(e.hours))}u</span>
								</div>
								<div class="drawer-entry-title">${e.title}</div>
								<div class="drawer-entry-date">${dateStr}</div>
							</div>
						</div>
					`;
				}).join('')}
			</div>

			<button class="btn-primary drawer-log-btn" id="drawer-log-hours-btn">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				Uren toevoegen
			</button>
		`;

		document.getElementById('drawer-log-hours-btn')?.addEventListener('click', () => {
			closeDrawer();
			openHoursModal(drawerProjectId, document.getElementById('drawer-project-title')!.textContent || '');
		});
	}

	// ── Hours modal ──────────────────────────────────────────────────────────
	const hoursModal        = document.getElementById('hours-modal')!;
	const hoursForm         = document.getElementById('hours-form') as HTMLFormElement;
	const hoursProjectIdEl  = document.getElementById('hours-project-id') as HTMLInputElement;
	const hoursPersonsCont  = document.getElementById('hours-persons-container')!;

	let hoursProfiles: any[] = [];

	async function loadHoursProfiles() {
		if (hoursProfiles.length > 0) return;
		const { data } = await supabase.from('profiles').select('id, full_name, username').order('full_name');
		hoursProfiles = data || [];
	}

	function buildHoursPersonRow(userId = '') {
		const row = document.createElement('div');
		row.className = 'person-row';
		row.innerHTML = `
			<select class="person-select" required>
				<option value="">Selecteer persoon</option>
				${hoursProfiles.map(p => `<option value="${p.id}" ${p.id === userId ? 'selected' : ''}>${p.full_name || p.username || 'Onbekend'}</option>`).join('')}
			</select>
			<div class="person-hours-wrap">
				<input type="number" class="person-hours" min="0.25" max="24" step="0.25" placeholder="uren" required />
				<span class="hours-unit">u</span>
			</div>
			<button type="button" class="remove-person-btn btn-icon" title="Verwijderen">
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
		`;
		row.querySelector('.remove-person-btn')!.addEventListener('click', () => {
			if (hoursPersonsCont.querySelectorAll('.person-row').length > 1) row.remove();
		});
		return row;
	}

	document.getElementById('hours-add-person-btn')?.addEventListener('click', () => {
		hoursPersonsCont.appendChild(buildHoursPersonRow());
	});

	async function openHoursModal(projectId: string, projectTitle: string) {
		await loadHoursProfiles();
		hoursForm.reset();
		hoursProjectIdEl.value = projectId;
		const chip = document.getElementById('hours-context-chip')!;
		document.getElementById('hours-context-text')!.textContent = projectTitle;
		chip.style.display = 'inline-flex';
		(document.getElementById('hours-date') as HTMLInputElement).value = new Date().toISOString().split('T')[0];

		hoursPersonsCont.innerHTML = '';
		const { data: { session } } = await supabase.auth.getSession();
		hoursPersonsCont.appendChild(buildHoursPersonRow(session?.user.id || ''));

		hoursModal.classList.add('active');
	}

	document.getElementById('hours-cancel-btn')?.addEventListener('click', () => hoursModal.classList.remove('active'));
	hoursModal.addEventListener('click', e => { if (e.target === hoursModal) hoursModal.classList.remove('active'); });

	hoursForm.addEventListener('submit', async e => {
		e.preventDefault();
		const { data: { session } } = await supabase.auth.getSession();
		if (!session) return;
		const fd      = new FormData(hoursForm);
		const title   = fd.get('title') as string;
		const desc    = (fd.get('description') as string) || null;
		const date    = fd.get('date') as string;
		const projId  = (fd.get('project_id') as string) || null;

		const rows = hoursPersonsCont.querySelectorAll('.person-row');
		const entries: any[] = [];
		for (const row of rows) {
			const uid = (row.querySelector('.person-select') as HTMLSelectElement).value;
			const hrs = parseFloat((row.querySelector('.person-hours') as HTMLInputElement).value);
			if (!uid || isNaN(hrs)) continue;
			entries.push({ user_id: uid, logged_by: session.user.id, title, description: desc, hours: hrs, date, project_id: projId });
		}
		if (entries.length === 0) return;
		const { error } = await supabase.from('time_entries').insert(entries);
		if (error) { alert(error.message); return; }
		hoursModal.classList.remove('active');
	});

	function setupActionButtons() {
		document.querySelectorAll('.view-hours-project').forEach(btn => {
			btn.addEventListener('click', async () => {
				const id    = (btn as HTMLElement).dataset.id!;
				const title = (btn as HTMLElement).dataset.title!;
				await openProjectHoursDrawer(id, title);
			});
		});

		document.querySelectorAll('.log-hours-project').forEach(btn => {
			btn.addEventListener('click', async () => {
				const id    = (btn as HTMLElement).dataset.id!;
				const title = (btn as HTMLElement).dataset.title!;
				await openHoursModal(id, title);
			});
		});

		document.querySelectorAll('.edit-project').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const id = (e.currentTarget as HTMLElement).closest('.project-card')?.getAttribute('data-id');
				if (id) openModal(id);
			});
		});

		document.querySelectorAll('.delete-project').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const id = (e.currentTarget as HTMLElement).closest('.project-card')?.getAttribute('data-id');
				if (id && confirm('Are you certain you wish to remove this project? This action cannot be undone.')) {
					const { error } = await supabase.from('projects').delete().eq('id', id);
					if (error) alert(error.message);
					else loadProjects();
				}
			});
		});
	}

	// Form Submission (Create or Update)
	projectForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(projectForm);
		const { data: { session } } = await supabase.auth.getSession();

		const projectData = {
			title: formData.get('title'),
			client: formData.get('client'),
			start_date: formData.get('start_date') || null,
			end_date: formData.get('end_date') || null,
			files_url: formData.get('files_url'),
			user_id: session?.user.id
		};

		let result;
		if (editingProjectId) {
			result = await supabase.from('projects').update(projectData).eq('id', editingProjectId);

			if (!result.error) {
				await supabase.from('notifications').insert({
					user_id: session?.user.id,
					type: 'project_updated',
					title: 'Project Updated',
					content: `Project "${projectData.title}" was updated.`,
					link: '/projects'
				});
			}
		} else {
			result = await supabase.from('projects').insert([projectData]);

			if (!result.error) {
				await supabase.from('notifications').insert({
					user_id: session?.user.id,
					type: 'project_created',
					title: 'New Project Initiated',
					content: `A new project "${projectData.title}" has been started.`,
					link: '/projects'
				});
			}
		}

		if (result.error) alert(result.error.message);
		else {
			closeModal();
			loadProjects();
		}
	});

	// Initial load
	loadProjects();
</script>

<AppLayout title="Projects | Gentlemen's Dashboard">
	<header class="page-header">
		<div>
			<h1 class="serif">Active <span class="gold-text italic">Projects</span></h1>
			<p class="subtitle">Manage and track all ongoing society initiatives.</p>
		</div>
		<button id="create-project-btn" class="btn-primary">+ Initiate New Project</button>
	</header>

	<div class="list-filters card">
		<div class="filters-top">
			<div class="search-wrap">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="project-search" placeholder="Zoeken op projectnaam, klant..." />
			</div>
		</div>
	</div>

	<div id="projects-container" class="projects-grid">
		<div class="empty-state card">
			<p>Loading the projects vault...</p>
		</div>
	</div>

	<!-- Drawer overlay -->
	<div id="drawer-overlay" class="drawer-overlay"></div>

	<!-- Per-project hours drawer -->
	<div id="project-hours-drawer" class="hours-drawer">
		<div class="drawer-inner card">
			<div class="drawer-header">
				<div>
					<h3 class="serif">Uren <span class="gold-text">overzicht</span></h3>
					<p id="drawer-project-title" class="drawer-subtitle"></p>
				</div>
				<button id="close-drawer-btn" class="btn-icon close-btn">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</button>
			</div>
			<div id="drawer-body" class="drawer-body"></div>
		</div>
	</div>

	<!-- Hours Modal -->
	<div id="hours-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 class="serif">Log <span class="gold-text">Uren</span></h2>
			<div id="hours-context-chip" class="hours-context-chip" style="display:none;">
				<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
				<span id="hours-context-text"></span>
			</div>
			<form id="hours-form">
				<input type="hidden" id="hours-project-id" name="project_id" />
				<div class="form-group">
					<label for="hours-title">Wat heb je gedaan? *</label>
					<input type="text" id="hours-title" name="title" required placeholder="Korte omschrijving van je werkzaamheden" />
				</div>
				<div class="form-group">
					<label for="hours-description">Toelichting</label>
					<textarea id="hours-description" name="description" rows="2" placeholder="Optionele uitleg..."></textarea>
				</div>
				<div class="form-group">
					<label for="hours-date">Datum *</label>
					<input type="date" id="hours-date" name="date" required />
				</div>
				<p class="persons-label">Voor wie schrijf je uren?</p>
				<div id="hours-persons-container" class="persons-container"></div>
				<button type="button" id="hours-add-person-btn" class="add-person-btn">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
					Persoon toevoegen
				</button>
				<div class="modal-actions">
					<button type="button" id="hours-cancel-btn" class="btn-secondary">Annuleren</button>
					<button type="submit" class="btn-primary">Uren opslaan</button>
				</div>
			</form>
		</div>
	</div>

	<!-- Project Modal -->
	<div id="project-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="modal-title" class="serif">New <span class="gold-text">Project</span></h2>
			<form id="project-form">
				<div class="form-group">
					<label for="title">Project Name *</label>
					<input type="text" id="title" name="title" required />
				</div>
				<div class="form-group">
					<label for="client">Client / Opdrachtgever</label>
					<input type="text" id="client" name="client" />
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="start_date">Start Date</label>
						<input type="date" id="start_date" name="start_date" />
					</div>
					<div class="form-group">
						<label for="end_date">End Date</label>
						<input type="date" id="end_date" name="end_date" />
					</div>
