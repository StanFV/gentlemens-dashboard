---
import AppLayout from '../layouts/AppLayout.astro';
---

<script>
	import { supabase } from '../lib/supabase';

	// State
	let editingProjectId: string | null = null;
	let allProjects: any[] = [];
	let profiles: any[] = [];
	let searchQuery = '';
	let drawerProjectId: string | null = null;
	let hoursModalProjectId: string | null = null;

	// UI Elements
	const createBtn = document.getElementById('create-project-btn');
	const projectModal = document.getElementById('project-modal');
	const modalTitle = document.getElementById('modal-title');
	const submitBtn = document.getElementById('submit-btn');
	const cancelBtn = document.getElementById('cancel-btn');
	const projectForm = document.getElementById('project-form') as HTMLFormElement;
	const container = document.getElementById('projects-container');
	const searchInput = document.getElementById('project-search') as HTMLInputElement;

	searchInput?.addEventListener('input', () => {
		searchQuery = searchInput.value.toLowerCase();
		renderProjects();
	});

	// Toggle Modal
	function openModal(editId: string | null = null) {
		editingProjectId = editId;
		if (editId) {
			modalTitle!.innerHTML = 'Edit <span class="gold-text">Project</span>';
			submitBtn!.textContent = 'Update Project';
			loadProjectIntoForm(editId);
		} else {
			modalTitle!.innerHTML = 'New <span class="gold-text">Project</span>';
			submitBtn!.textContent = 'Initiate Project';
			projectForm.reset();
		}
		projectModal?.classList.add('active');
	}

	function closeModal() {
		projectModal?.classList.remove('active');
		editingProjectId = null;
		projectForm.reset();
	}

	createBtn?.addEventListener('click', () => openModal());
	cancelBtn?.addEventListener('click', closeModal);

	async function loadProjectIntoForm(id: string) {
		const { data } = await supabase.from('projects').select('*').eq('id', id).single();
		if (data) {
			(document.getElementById('title') as HTMLInputElement).value = data.title;
			(document.getElementById('client') as HTMLInputElement).value = data.client || '';
			(document.getElementById('start_date') as HTMLInputElement).value = data.start_date || '';
			(document.getElementById('end_date') as HTMLInputElement).value = data.end_date || '';
			(document.getElementById('files_url') as HTMLInputElement).value = data.files_url || '';
		}
	}

	// Fetch and Render Projects
	async function loadProjects() {
		const { data: projects, error } = await supabase
			.from('projects')
			.select('*')
			.order('created_at', { ascending: false });

		if (!container) return;

		if (error) {
			container.innerHTML = `<div class="empty-state card"><p>Error: ${error.message}</p></div>`;
			return;
		}

		allProjects = projects || [];
		renderProjects();
	}

	function renderProjects() {
		if (!container) return;
		const filtered = allProjects.filter(p =>
			!searchQuery ||
			(p.title || '').toLowerCase().includes(searchQuery) ||
			(p.client || '').toLowerCase().includes(searchQuery)
		);

		if (filtered.length === 0) {
			container.innerHTML = `<div class="empty-state card"><p>${allProjects.length === 0 ? 'No projects found. Time to start something grand.' : 'No projects match your search.'}</p></div>`;
			return;
		}

		container.innerHTML = filtered.map(project => `
			<div class="project-card card" data-id="${project.id}">
				<div class="p-header">
					<div class="p-main-info">
						<span class="p-category">${project.category || 'General'}</span>
						<h2 class="serif">${project.title}</h2>
						<p class="p-client">Client: <span>${project.client || 'Internal'}</span></p>
					</div>
					<div class="p-actions">
						<button class="btn-icon view-hours-project" title="View Hours">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>
						</button>
						<button class="btn-icon log-hours-project" title="Log Hours">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
						</button>
						<button class="btn-icon edit-project" title="Edit">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
						</button>
						<button class="btn-icon delete-project" title="Delete">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H5c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
						</button>
					</div>
				</div>

				<div class="p-dates">
					<div class="date-item">
						<label>Started</label>
						<span>${project.start_date || 'TBD'}</span>
					</div>
					<div class="date-item">
						<label>Deadline</label>
						<span>${project.end_date || 'None'}</span>
					</div>
				</div>

				<div class="p-footer">
					${project.files_url ? `
						<a href="${project.files_url}" target="_blank" class="btn-secondary files-link">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><polyline points="14 2 14 8 20 8"/></svg>
							Files
						</a>
					` : `<span class="no-files">No files</span>`}
					<div class="p-progress-mini">
						<div class="p-bar-mini"><div class="p-fill-mini" style="width: ${project.progress}%"></div></div>
						<span class="p-num-mini">${project.progress}%</span>
					</div>
				</div>
			</div>
		`).join('');

		setupActionButtons();
	}

	function setupActionButtons() {
		document.querySelectorAll('.edit-project').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const id = (e.currentTarget as HTMLElement).closest('.project-card')?.getAttribute('data-id');
				if (id) openModal(id);
			});
		});

		document.querySelectorAll('.delete-project').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const id = (e.currentTarget as HTMLElement).closest('.project-card')?.getAttribute('data-id');
				if (id && confirm('Are you certain you wish to remove this project? This action cannot be undone.')) {
					const { error } = await supabase.from('projects').delete().eq('id', id);
					if (error) alert(error.message);
					else loadProjects();
				}
			});
		});

		document.querySelectorAll('.view-hours-project').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const card = (e.currentTarget as HTMLElement).closest('.project-card');
				const id = card?.getAttribute('data-id');
				const title = card?.querySelector('h2')?.textContent || '';
				if (id) openProjectHoursDrawer(id, title);
			});
		});

		document.querySelectorAll('.log-hours-project').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const card = (e.currentTarget as HTMLElement).closest('.project-card');
				const id = card?.getAttribute('data-id');
				const title = card?.querySelector('h2')?.textContent || '';
				if (id) openHoursModal(id, title);
			});
		});
	}

	// Hours Drawer
	async function openProjectHoursDrawer(projectId: string, projectTitle: string) {
		drawerProjectId = projectId;
		const drawer = document.getElementById('project-hours-drawer');
		const overlay = document.getElementById('drawer-overlay');
		const drawerTitleEl = document.getElementById('drawer-project-title');
		const drawerBody = document.getElementById('drawer-body');

		if (drawerTitleEl) drawerTitleEl.textContent = projectTitle;
		if (drawerBody) drawerBody.innerHTML = '<p style="color:var(--color-text-muted);font-style:italic;padding:1rem 0">Loading...</p>';
		drawer?.classList.add('active');
		overlay?.classList.add('active');

		const { data: entries, error } = await supabase
			.from('time_entries')
			.select('*, profiles!time_entries_profile_fkey(full_name, username, avatar_url)')
			.eq('project_id', projectId)
			.order('date', { ascending: false });

		if (error || !entries) {
			if (drawerBody) drawerBody.innerHTML = `<p style="color:var(--color-text-muted)">Error loading hours.</p>`;
			return;
		}

		const total = entries.reduce((sum, e) => sum + (e.hours || 0), 0);

		const personMap: Record<string, { name: string; avatar: string; hours: number }> = {};
		for (const e of entries) {
			const profile = e.profiles;
			const name = profile?.full_name || profile?.username || 'Unknown';
			const avatar = profile?.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=1c1917&color=c5a059`;
			if (!personMap[name]) personMap[name] = { name, avatar, hours: 0 };
			personMap[name].hours += e.hours || 0;
		}
		const persons = Object.values(personMap).sort((a, b) => b.hours - a.hours);
		const maxHours = persons[0]?.hours || 1;

		const personsHTML = persons.map(p => `
			<div class="drawer-person">
				<img src="${p.avatar}" class="drawer-avatar" />
				<div class="drawer-person-info">
					<span class="drawer-person-name">${p.name}</span>
					<div class="drawer-bar-wrap">
						<div class="drawer-bar" style="width:${Math.round((p.hours / maxHours) * 100)}%"></div>
					</div>
				</div>
				<span class="drawer-person-hours">${p.hours}h</span>
			</div>
		`).join('');

		const timelineHTML = entries.map(e => {
			const profile = e.profiles;
			const name = profile?.full_name || profile?.username || 'Unknown';
			return `
				<div class="drawer-entry">
					<span class="drawer-entry-date">${e.date || ''}</span>
					<span class="drawer-entry-name">${name}</span>
					<span class="drawer-entry-hours">${e.hours}h</span>
					${e.description ? `<span class="drawer-entry-desc">${e.description}</span>` : ''}
				</div>
			`;
		}).join('');

		if (drawerBody) drawerBody.innerHTML = `
			<div class="drawer-total">
				<span class="drawer-total-label">Total Hours</span>
				<span class="drawer-total-value">${total}h</span>
			</div>
			${persons.length > 0 ? `
				<p class="drawer-section-label">Per Person</p>
				<div class="drawer-persons">${personsHTML}</div>
			` : ''}
			${entries.length > 0 ? `
				<p class="drawer-section-label">Timeline</p>
				<div class="drawer-timeline">${timelineHTML}</div>
			` : '<p style="color:var(--color-text-muted);font-style:italic;margin-top:1rem">No hours logged yet.</p>'}
			<button class="drawer-log-btn btn-primary" id="drawer-log-hours-btn">+ Uren toevoegen</button>
		`;

		document.getElementById('drawer-log-hours-btn')?.addEventListener('click', () => {
			closeDrawer();
			const project = allProjects.find(p => p.id === projectId);
			openHoursModal(projectId, project?.title || '');
		});
	}

	function closeDrawer() {
		document.getElementById('project-hours-drawer')?.classList.remove('active');
		document.getElementById('drawer-overlay')?.classList.remove('active');
		drawerProjectId = null;
	}

	document.getElementById('drawer-close-btn')?.addEventListener('click', closeDrawer);
	document.getElementById('drawer-overlay')?.addEventListener('click', closeDrawer);

	// Hours Modal (multi-person)
	function openHoursModal(projectId: string, projectTitle: string) {
		hoursModalProjectId = projectId;
		const modal = document.getElementById('hours-modal');
		const titleEl = document.getElementById('hours-modal-title');
		if (titleEl) titleEl.textContent = `Log Hours — ${projectTitle}`;
		const dateEl = document.getElementById('hours-date') as HTMLInputElement;
		if (dateEl) dateEl.value = new Date().toISOString().split('T')[0];
		const descEl = document.getElementById('hours-desc') as HTMLInputElement;
		if (descEl) descEl.value = '';
		resetPersonRows();
		modal?.classList.add('active');
	}

	function closeHoursModal() {
		document.getElementById('hours-modal')?.classList.remove('active');
		hoursModalProjectId = null;
	}

	document.getElementById('hours-cancel-btn')?.addEventListener('click', closeHoursModal);

	function buildPersonRow() {
		const opts = profiles.map(p => `<option value="${p.id}">${p.full_name || p.username}</option>`).join('');
		return `
			<div class="person-row">
				<select class="person-select form-ctrl">${opts}</select>
				<input type="number" class="hours-input form-ctrl" placeholder="Uren" min="0.5" step="0.5" />
				<button type="button" class="remove-row-btn btn-icon" title="Remove">×</button>
			</div>
		`;
	}

	function resetPersonRows() {
		const rowsEl = document.getElementById('persons-rows');
		if (!rowsEl) return;
		rowsEl.innerHTML = buildPersonRow();
		setupRemoveBtns();
	}

	function setupRemoveBtns() {
		document.querySelectorAll('.remove-row-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const row = (e.currentTarget as HTMLElement).closest('.person-row');
				const rowsEl = document.getElementById('persons-rows');
				if (rowsEl && rowsEl.querySelectorAll('.person-row').length > 1) row?.remove();
			});
		});
	}

	document.getElementById('add-person-btn')?.addEventListener('click', () => {
		const rowsEl = document.getElementById('persons-rows');
		if (!rowsEl) return;
		const tmp = document.createElement('div');
		tmp.innerHTML = buildPersonRow();
		rowsEl.appendChild(tmp.firstElementChild!);
		setupRemoveBtns();
	});

	document.getElementById('hours-submit-btn')?.addEventListener('click', async () => {
		if (!hoursModalProjectId) return;
		const rows = document.querySelectorAll('#persons-rows .person-row');
		const date = (document.getElementById('hours-date') as HTMLInputElement)?.value || new Date().toISOString().split('T')[0];
		const description = (document.getElementById('hours-desc') as HTMLInputElement)?.value || '';
		const { data: { session } } = await supabase.auth.getSession();

		const inserts: any[] = [];
		rows.forEach(row => {
			const userId = (row.querySelector('.person-select') as HTMLSelectElement)?.value;
			const hours = parseFloat((row.querySelector('.hours-input') as HTMLInputElement)?.value || '0');
			if (userId && hours > 0) {
				inserts.push({ user_id: userId, project_id: hoursModalProjectId, hours, date, description, logged_by: session?.user.id });
			}
		});

		if (inserts.length === 0) { alert('Voer minimaal één geldige invoer in.'); return; }
		const { error } = await supabase.from('time_entries').insert(inserts);
		if (error) alert(error.message);
		else {
			closeHoursModal();
			await supabase.from('notifications').insert({
				user_id: session?.user.id,
				type: 'hours_logged',
				title: 'Uren Geregistreerd',
				content: `${inserts.reduce((s, i) => s + i.hours, 0)} uren geregistreerd voor project.`,
				link: '/projects'
			});
		}
	});

	// Form Submission (Create or Update)
	projectForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(projectForm);
		const { data: { session } } = await supabase.auth.getSession();

		const projectData = {
			title: formData.get('title'),
			client: formData.get('client'),
			start_date: formData.get('start_date') || null,
			end_date: formData.get('end_date') || null,
			files_url: formData.get('files_url'),
			user_id: session?.user.id
		};

		let result;
		if (editingProjectId) {
			result = await supabase.from('projects').update(projectData).eq('id', editingProjectId);
			if (!result.error) {
				await supabase.from('notifications').insert({
					user_id: session?.user.id,
					type: 'project_updated',
					title: 'Project Updated',
					content: `Project "${projectData.title}" was updated.`,
					link: '/projects'
				});
			}
		} else {
			result = await supabase.from('projects').insert([projectData]);
			if (!result.error) {
				await supabase.from('notifications').insert({
					user_id: session?.user.id,
					type: 'project_created',
					title: 'New Project Initiated',
					content: `A new project "${projectData.title}" has been started.`,
					link: '/projects'
				});
			}
		}

		if (result.error) alert(result.error.message);
		else {
			closeModal();
			loadProjects();
		}
	});

	async function loadProfiles() {
		const { data } = await supabase.from('profiles').select('id, full_name, username');
		profiles = data || [];
	}

	// Initial load
	loadProfiles().then(() => loadProjects());
</script>

<AppLayout title="Projects | Gentlemen's Dashboard">
	<header class="page-header">
		<div>
			<h1 class="serif">Active <span class="gold-text italic">Projects</span></h1>
			<p class="subtitle">Manage and track all ongoing society initiatives.</p>
		</div>
		<button id="create-project-btn" class="btn-primary">+ Initiate New Project</button>
	</header>

	<div class="list-filters card">
		<div class="search-wrap">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
			<input type="text" id="project-search" placeholder="Search projects..." />
		</div>
	</div>

	<div id="projects-container" class="projects-grid">
		<div class="empty-state card">
			<p>Loading the projects vault...</p>
		</div>
	</div>

	<!-- Project Modal -->
	<div id="project-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="modal-title" class="serif">New <span class="gold-text">Project</span></h2>
			<form id="project-form">
				<div class="form-group">
					<label for="title">Project Name *</label>
					<input type="text" id="title" name="title" required />
				</div>
				<div class="form-group">
					<label for="client">Client / Opdrachtgever</label>
					<input type="text" id="client" name="client" />
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="start_date">Start Date</label>
						<input type="date" id="start_date" name="start_date" />
					</div>
					<div class="form-group">
						<label for="end_date">End Date</label>
						<input type="date" id="end_date" name="end_date" />
					</div>
				</div>
				<div class="form-group">
					<label for="files_url">Storage URL</label>
					<input type="url" id="files_url" name="files_url" placeholder="https://..." />
				</div>
				<div class="modal-actions">
					<button type="button" id="cancel-btn" class="btn-secondary">Cancel</button>
					<button type="submit" id="submit-btn" class="btn-primary">Initiate Project</button>
				</div>
			</form>
		</div>
	</div>

	<!-- Hours Modal -->
	<div id="hours-modal" class="modal-overlay">
		<div class="modal-card card">
			<h2 id="hours-modal-title" class="serif">Log Hours</h2>
			<div class="form-group">
				<label>Datum</label>
				<input type="date" id="hours-date" class="form-ctrl" style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:.75rem 1rem;color:var(--color-text);outline:none;" />
			</div>
			<div class="form-group">
				<label>Omschrijving</label>
				<input type="text" id="hours-desc" class="form-ctrl" placeholder="Wat is er gedaan?" style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:.75rem 1rem;color:var(--color-text);font-family:inherit;outline:none;" />
			</div>
			<div id="persons-rows" class="persons-rows"></div>
			<button type="button" id="add-person-btn" class="add-person-btn">+ Persoon toevoegen</button>
			<div class="modal-actions">
				<button type="button" id="hours-cancel-btn" class="btn-secondary">Annuleren</button>
				<button type="button" id="hours-submit-btn" class="btn-primary">Uren Opslaan</button>
			</div>
		</div>
	</div>

	<!-- Hours Drawer -->
	<div id="drawer-overlay" class="drawer-overlay"></div>
	<div id="project-hours-drawer" class="hours-drawer">
		<div class="drawer-inner card">
			<div class="drawer-header">
				<h3 id="drawer-project-title" class="serif"></h3>
				<button id="drawer-close-btn" class="btn-icon" style="font-size:1.2rem;width:32px;height:32px;">×</button>
			</div>
			<div id="drawer-body" class="drawer-body"></div>
		</div>
	</div>
</AppLayout>

<style is:global>
	.page-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
	h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.list-filters { padding: 1rem 1.25rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem; }
	.search-wrap { display: flex; align-items: center; gap: 0.6rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.6rem 1rem; flex: 1; }
	.search-wrap svg { opacity: 0.4; flex-shrink: 0; }
	.search-wrap input { background: transparent; border: none; outline: none; color: var(--color-text); font-size: 0.9rem; font-family: inherit; width: 100%; }
	.search-wrap input::placeholder { color: var(--color-text-muted); }

	.projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem; }

	.empty-state { grid-column: 1 / -1; padding: 4rem; text-align: center; color: var(--color-text-muted); font-style: italic; }

	.project-card { padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; transition: transform 0.3s; position: relative; }
	.project-card:hover { transform: translateY(-5px); border-color: var(--color-primary); }

	.p-header { display: flex; justify-content: space-between; align-items: flex-start; }
	.p-category { font-size: 0.7rem; text-transform: uppercase; color: var(--color-primary); letter-spacing: 0.1em; margin-bottom: 0.5rem; display: block; }
	.p-header h2 { font-size: 1.6rem; margin-bottom: 0.25rem; }
