---
import AppLayout from '../layouts/AppLayout.astro';
import { supabase } from '../lib/supabase';

// Fetch data from Supabase
const { data: statsData } = await supabase.from('stats').select('*');
const { data: projectsData } = await supabase.from('projects').select('*').order('created_at', { ascending: false });
const { data: activitiesData } = await supabase.from('activities').select('*').order('created_at', { ascending: false }).limit(5);

// Fallback data if DB is empty or error
const stats = statsData || [
	{ label: 'Active Projects', value: '0', trend: '0%' },
	{ label: 'Total Members', value: '0', trend: '0' },
	{ label: 'Monthly Budget', value: '€0', trend: '0%' },
];

const projects = projectsData || [];
const activities = activitiesData || [];
---

<AppLayout title="Dashboard | Gentlemen's Dashboard">
	<section class="hero">
		<h1 class="serif">Good evening, <br/><span class="gold-text italic">Gentlemen.</span></h1>
		<p class="subtitle">System operational. {projects.length} projects require your attention today.</p>
	</section>

	<div class="grid-layout">
		<!-- Stats Section -->
		<div class="stats-grid">
			{stats.map(stat => (
				<div class="stat-card">
					<span class="stat-label">{stat.label}</span>
					<div class="stat-main">
						<span class="stat-value">{stat.value}</span>
						<span class={`stat-trend ${stat.trend?.startsWith('+') ? 'up' : 'down'}`}>{stat.trend}</span>
					</div>
				</div>
			))}
		</div>

		<!-- Projects Section -->
		<section class="card project-card">
			<div class="card-header">
				<h2 class="serif">Active Projects</h2>
				<button class="text-btn">View all</button>
			</div>
			<div class="project-items">
				{projects.map(p => (
					<div class="p-item">
						<div class="p-header">
							<span class="p-cat">{p.category}</span>
							<h3 class="p-title">{p.title}</h3>
						</div>
						<div class="p-progress">
							<div class="p-bar"><div class="p-fill" style={`width: ${p.progress}%`}></div></div>
							<span class="p-num">{p.progress}%</span>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Activity Section -->
		<section class="card activity-card">
			<div class="card-header">
				<h2 class="serif">Recent Log</h2>
			</div>
			<div class="activity-items">
				{activities.map(activity => (
					<div class="a-item">
						<span class="a-time">{new Date(activity.created_at).toLocaleTimeString('nl-NL', { hour: '2-digit', minute: '2-digit' })}</span>
						<p class="a-desc">{activity.description}</p>
					</div>
				))}
			</div>
		</section>
	</div>
</AppLayout>

<style>
	.hero { margin-bottom: 4rem; }
	.hero h1 { font-size: 4.5rem; line-height: 0.95; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }
	.subtitle { color: var(--color-text-muted); font-size: 1.1rem; max-width: 400px; }

	/* --- Grid & Cards --- */
	.grid-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; }
	.stats-grid { grid-column: span 2; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 1rem; }
	
	.stat-card {
		background: var(--color-card); border: 1px solid var(--color-border);
		padding: 2rem; border-radius: 20px;
	}
	.stat-label { color: var(--color-text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 1rem; }
	.stat-main { display: flex; align-items: baseline; gap: 1rem; }
	.stat-value { font-size: 2.5rem; font-family: var(--font-serif); }
	.stat-trend { font-size: 0.8rem; padding: 0.2rem 0.5rem; border-radius: 4px; }
	.stat-trend.up { color: #a7f3d0; background: rgba(167, 243, 208, 0.1); }
	.stat-trend.down { color: #fecaca; background: rgba(254, 202, 202, 0.1); }

	.card { background: var(--color-card); border: 1px solid var(--color-border); border-radius: 24px; padding: 2rem; }
	.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
	.card-header h2 { font-size: 1.8rem; }
	.text-btn { background: transparent; border: none; color: var(--color-primary); cursor: pointer; font-size: 0.9rem; }

	.project-items { display: flex; flex-direction: column; gap: 2rem; }
	.p-header { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.75rem; }
	.p-cat { font-size: 0.7rem; text-transform: uppercase; color: var(--color-primary); letter-spacing: 0.1em; }
	.p-title { font-size: 1.1rem; font-weight: 500; }
	.p-progress { display: flex; align-items: center; gap: 1rem; }
	.p-bar { flex-grow: 1; height: 2px; background: var(--color-border); border-radius: 100px; overflow: hidden; }
	.p-fill { height: 100%; background: var(--color-primary); border-radius: 100px; }
	.p-num { font-size: 0.8rem; color: var(--color-text-muted); min-width: 35px; }

	.activity-items { display: flex; flex-direction: column; gap: 1.5rem; }
	.a-item { display: flex; gap: 1.5rem; align-items: flex-start; }
	.a-time { font-size: 0.8rem; color: var(--color-text-muted); min-width: 70px; padding-top: 0.2rem; }
	.a-desc { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.5; }

	@media (max-width: 900px) {
		.grid-layout { grid-template-columns: 1fr; }
		.stats-grid { grid-template-columns: 1fr; grid-column: span 1; gap: 1rem; }
	}
</style>
