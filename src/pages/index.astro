---
import Layout from '../layouts/Layout.astro';

// Dummy data voor projecten
const projects = [
	{ title: 'De Societeit Website', status: 'In behandeling', progress: 65, tag: 'Web' },
	{ title: 'Inkoop Whiskey Voorraad', status: 'Voltooid', progress: 100, tag: 'Logistiek' },
	{ title: 'Jaarlijks Gala 2026', status: 'Planning', progress: 20, tag: 'Event' },
];

// Dummy data voor recente activiteiten
const activities = [
	{ time: '14:20', desc: 'Nieuw lid geaccepteerd: James B.', icon: '👤' },
	{ time: 'Gisteren', desc: 'Systeem-update uitgevoerd naar v1.2', icon: '⚙️' },
	{ time: 'Gisteren', desc: 'Project "Gala" aangemaakt', icon: '📅' },
];
---

<Layout title="Gentlemen's Dashboard">
	<div class="app-container">
		<!-- Sidebar (Verborgen op mobiel, onderkant op mobiel?) -->
		<nav class="sidebar">
			<div class="logo">
				<span class="logo-icon">G</span>
				<span class="logo-text">Gentlemen's</span>
			</div>
			<ul class="nav-links">
				<li class="active"><a href="#"><span class="icon">🏠</span> <span class="label">Dashboard</span></a></li>
				<li><a href="#"><span class="icon">💼</span> <span class="label">Projecten</span></a></li>
				<li><a href="#"><span class="icon">👥</span> <span class="label">Leden</span></a></li>
				<li><a href="#"><span class="icon">💶</span> <span class="label">Financiën</span></a></li>
			</ul>
			<div class="sidebar-footer">
				<div class="profile">
					<div class="avatar">S</div>
					<div class="profile-info">
						<span class="name">Stan F.V.</span>
					</div>
				</div>
			</div>
		</nav>

		<!-- Main Content -->
		<main class="content">
			<header class="top-bar">
				<div class="search-bar">
					<input type="text" placeholder="Zoek..." />
				</div>
				<div class="top-actions">
					<button class="btn-icon">🔔</button>
					<button class="btn-primary">+ Nieuw</button>
				</div>
			</header>

			<div class="scroll-area">
				<div class="dashboard-grid">
					<!-- Welkomst Sectie -->
					<section class="welcome-card">
						<div class="welcome-text">
							<h1>Goedenavond, <span class="text-gradient">Gentlemen</span></h1>
							<p>Systeem is operationeel.</p>
						</div>
					</section>

					<!-- Stats -->
					<div class="stats-row">
						<div class="stat-card">
							<span class="stat-label">Projecten</span>
							<span class="stat-value">12</span>
						</div>
						<div class="stat-card">
							<span class="stat-label">Leden</span>
							<span class="stat-value">48</span>
						</div>
						<div class="stat-card">
							<span class="stat-label">Budget</span>
							<span class="stat-value">€ 4.2k</span>
						</div>
					</div>

					<!-- Projecten Lijst -->
					<section class="panel projects-panel">
						<div class="panel-header">
							<h2>Projecten</h2>
						</div>
						<div class="project-list">
							{projects.map(project => (
								<div class="project-item">
									<div class="project-info">
										<h3>{project.title}</h3>
										<span class="project-status">{project.progress}%</span>
									</div>
									<div class="progress-bar">
										<div class="progress-fill" style={`width: ${project.progress}%`}></div>
									</div>
								</div>
							))}
						</div>
					</section>

					<!-- Logboek -->
					<section class="panel activity-panel">
						<div class="panel-header">
							<h2>Logboek</h2>
						</div>
						<div class="activity-list">
							{activities.map(activity => (
								<div class="activity-item">
									<div class="activity-icon">{activity.icon}</div>
									<div class="activity-content">
										<p>{activity.desc}</p>
										<span class="activity-time">{activity.time}</span>
									</div>
								</div>
							))}
						</div>
					</section>
				</div>
			</div>
		</main>
	</div>
</Layout>

<style>
	/* --- Layout & Scrolling --- */
	.app-container {
		display: flex;
		height: 100vh;
		overflow: hidden; /* Voorkom body scroll */
	}

	.content {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		height: 100vh;
		background: var(--color-bg);
		overflow: hidden;
	}

	.scroll-area {
		flex-grow: 1;
		overflow-y: auto;
		padding: 0 2rem 2rem 2rem;
		/* Custom scrollbar voor chique look */
		scrollbar-width: thin;
		scrollbar-color: var(--color-secondary) transparent;
	}

	.scroll-area::-webkit-scrollbar { width: 6px; }
	.scroll-area::-webkit-scrollbar-track { background: transparent; }
	.scroll-area::-webkit-scrollbar-thumb { background: var(--color-secondary); border-radius: 10px; }

	/* --- Sidebar --- */
	.sidebar {
		width: 240px;
		background-color: var(--color-primary);
		border-right: 1px solid var(--color-secondary);
		display: flex;
		flex-direction: column;
		flex-shrink: 0;
	}

	.logo { padding: 2rem; display: flex; align-items: center; gap: 0.8rem; }
	.logo-icon { background: var(--color-accent); color: var(--color-bg); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-weight: 900; border-radius: 4px; }
	.logo-text { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; }

	.nav-links { list-style: none; padding: 0; margin: 0; flex-grow: 1; }
	.nav-links a { color: var(--color-text-muted); text-decoration: none; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; transition: all 0.2s; border-left: 3px solid transparent; }
	.nav-links li.active a, .nav-links a:hover { color: var(--color-accent); background: rgba(197, 160, 89, 0.05); border-left-color: var(--color-accent); }

	.sidebar-footer { padding: 1rem 2rem; border-top: 1px solid var(--color-secondary); }
	.profile { display: flex; align-items: center; gap: 0.8rem; }
	.avatar { width: 32px; height: 32px; background: var(--color-secondary); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-accent); border: 1px solid var(--color-accent); font-size: 0.8rem; }
	.name { font-weight: 600; font-size: 0.85rem; }

	/* --- Content UI --- */
	.top-bar { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 2rem; }
	.search-bar input { background: var(--color-primary); border: 1px solid var(--color-secondary); padding: 0.5rem 1rem; border-radius: 20px; color: var(--color-text); width: 200px; font-size: 0.9rem; }
	.btn-primary { background: var(--color-accent); color: var(--color-bg); border: none; padding: 0.5rem 1rem; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem; }
	.btn-icon { background: transparent; border: 1px solid var(--color-secondary); color: var(--color-text); padding: 0.5rem; border-radius: 6px; cursor: pointer; }

	.dashboard-grid { display: grid; grid-template-columns: 2fr 1.2fr; gap: 1.5rem; }
	.welcome-card { grid-column: span 2; background: linear-gradient(90deg, var(--color-primary), transparent); padding: 2rem; border-radius: 12px; border-left: 4px solid var(--color-accent); margin-bottom: 0.5rem; }
	.welcome-card h1 { font-size: 2rem; margin: 0; }
	.welcome-card p { margin: 0.5rem 0 0 0; color: var(--color-text-muted); }

	.stats-row { grid-column: span 2; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
	.stat-card { background: var(--color-primary); padding: 1.2rem; border-radius: 12px; border: 1px solid var(--color-secondary); }
	.stat-label { color: var(--color-text-muted); font-size: 0.8rem; display: block; }
	.stat-value { font-size: 1.5rem; font-weight: 700; color: var(--color-accent); }

	.panel { background: var(--color-primary); border-radius: 12px; border: 1px solid var(--color-secondary); padding: 1.2rem; }
	.panel-header { margin-bottom: 1rem; border-bottom: 1px solid var(--color-secondary); padding-bottom: 0.5rem; }
	.panel-header h2 { font-size: 1.1rem; margin: 0; }

	.project-list { display: flex; flex-direction: column; gap: 1rem; }
	.project-info { display: flex; justify-content: space-between; margin-bottom: 0.3rem; }
	.project-info h3 { font-size: 0.95rem; margin: 0; }
	.project-status { font-size: 0.8rem; color: var(--color-text-muted); }
	.progress-bar { height: 4px; background: var(--color-bg); border-radius: 2px; overflow: hidden; }
	.progress-fill { height: 100%; background: var(--color-accent); }

	.activity-list { display: flex; flex-direction: column; gap: 1rem; }
	.activity-item { display: flex; gap: 0.8rem; }
	.activity-icon { font-size: 1rem; }
	.activity-content p { margin: 0; font-size: 0.85rem; }
	.activity-time { font-size: 0.7rem; color: var(--color-text-muted); }

	.text-gradient { background: linear-gradient(45deg, var(--color-accent), #f3e5ab); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

	/* --- Mobiele Optimalisatie (Smartphone Verticaal) --- */
	@media (max-width: 768px) {
		.app-container { flex-direction: column; overflow: auto; height: auto; }
		.sidebar { width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--color-secondary); position: fixed; bottom: 0; z-index: 100; padding: 0; }
		.logo { display: none; }
		.nav-links { display: flex; justify-content: space-around; width: 100%; }
		.nav-links a { padding: 1rem; flex-direction: column; gap: 0.2rem; border-left: none; border-top: 3px solid transparent; }
		.nav-links li.active a { border-left: none; border-top-color: var(--color-accent); }
		.nav-links .label { font-size: 0.6rem; text-transform: uppercase; }
		.sidebar-footer { display: none; }

		.content { height: auto; padding-bottom: 80px; overflow: visible; width: 100%; max-width: 100%; }
		.scroll-area { overflow: visible; padding: 1rem; }
		.top-bar { padding: 1rem; }
		.search-bar input { width: 140px; }

		.dashboard-grid { grid-template-columns: 1fr; }
		.welcome-card, .stats-row { grid-column: span 1; }
		.stats-row { grid-template-columns: 1fr; gap: 1rem; }
		.welcome-card h1 { font-size: 1.5rem; }
	}
</style>
