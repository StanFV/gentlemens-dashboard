---
import Layout from '../layouts/Layout.astro';

// Dummy data
const stats = [
	{ label: 'Active Projects', value: '12', trend: '+14%' },
	{ label: 'Total Members', value: '48', trend: '+2' },
	{ label: 'Monthly Budget', value: '€4.2k', trend: '-5%' },
];

const projects = [
	{ title: 'Sociëteit Website', category: 'Design', progress: 65 },
	{ title: 'Whiskey Inventory', category: 'Logistics', progress: 100 },
	{ title: 'Annual Gala 2026', category: 'Events', progress: 20 },
];
---

<Layout title="Gentlemen's Dashboard">
	<div class="app">
		<!-- Sidebar -->
		<aside class="sidebar">
			<div class="brand">
				<div class="logo">G</div>
				<span class="brand-name serif">Gentlemen</span>
			</div>
			
			<nav class="nav">
				<a href="#" class="nav-item active">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
					Dashboard
				</a>
				<a href="#" class="nav-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
					Projects
				</a>
				<a href="#" class="nav-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					Members
				</a>
				<a href="#" class="nav-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
					Treasury
				</a>
				<a href="#" class="nav-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><polyline points="21 8 21 21 3 21 3 8"/><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M10 12h4"/></svg>
					Archive
				</a>
			</nav>

			<div class="sidebar-bottom">
				<div class="user-pill">
					<div class="user-avatar">SF</div>
					<div class="user-meta">
						<span class="user-name">Stan F.V.</span>
						<span class="user-role">Administrator</span>
					</div>
				</div>
			</div>
		</aside>

		<!-- Main Content -->
		<main class="main">
			<header class="header">
				<div class="search">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
					<input type="text" placeholder="Quick search..." />
				</div>
				<div class="header-actions">
					<button class="btn-secondary">Notifications</button>
					<button class="btn-primary">Create New</button>
				</div>
			</header>

			<div class="scroll-container">
				<div class="view">
					<section class="hero">
						<h1 class="serif">Good evening, <br/><span class="gold-text italic">Gentlemen.</span></h1>
						<p class="subtitle">System operational. 3 projects require your attention today.</p>
					</section>

					<div class="grid-layout">
						<!-- Stats Section -->
						<div class="stats-grid">
							{stats.map(stat => (
								<div class="stat-card">
									<span class="stat-label">{stat.label}</span>
									<div class="stat-main">
										<span class="stat-value">{stat.value}</span>
										<span class={`stat-trend ${stat.trend.startsWith('+') ? 'up' : 'down'}`}>{stat.trend}</span>
									</div>
								</div>
							))}
						</div>

						<!-- Projects Section -->
						<section class="card project-card">
							<div class="card-header">
								<h2 class="serif">Active Projects</h2>
								<button class="text-btn">View all</button>
							</div>
							<div class="project-items">
								{projects.map(p => (
									<div class="p-item">
										<div class="p-header">
											<span class="p-cat">{p.category}</span>
											<h3 class="p-title">{p.title}</h3>
										</div>
										<div class="p-progress">
											<div class="p-bar"><div class="p-fill" style={`width: ${p.progress}%`}></div></div>
											<span class="p-num">{p.progress}%</span>
										</div>
									</div>
								))}
							</div>
						</section>

						<!-- Activity Section -->
						<section class="card activity-card">
							<div class="card-header">
								<h2 class="serif">Recent Log</h2>
							</div>
							<div class="activity-items">
								<div class="a-item">
									<span class="a-time">14:20</span>
									<p class="a-desc">New member <span class="white">James B.</span> approved</p>
								</div>
								<div class="a-item">
									<span class="a-time">Yesterday</span>
									<p class="a-desc">Vault security <span class="white">v1.2</span> deployed</p>
								</div>
								<div class="a-item">
									<span class="a-time">May 09</span>
									<p class="a-desc">Gala planning <span class="white">Phase 1</span> complete</p>
								</div>
							</div>
						</section>
					</div>
				</div>
			</div>
		</main>
	</div>
</Layout>

<style>
	.app {
		display: flex;
		height: 100vh;
		background: var(--color-bg);
	}

	/* --- Sidebar --- */
	.sidebar {
		width: 280px;
		background: var(--color-surface);
		border-right: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		padding: 3rem 2rem;
		flex-shrink: 0;
	}

	.brand { display: flex; align-items: center; gap: 1rem; margin-bottom: 4rem; }
	.logo { 
		width: 32px; height: 32px; border: 1px solid var(--color-primary); 
		color: var(--color-primary); display: flex; align-items: center; 
		justify-content: center; font-family: var(--font-serif); font-size: 1.2rem;
	}
	.brand-name { font-size: 1.5rem; letter-spacing: -0.02em; }

	.nav { display: flex; flex-direction: column; gap: 0.5rem; flex-grow: 1; }
	.nav-item {
		text-decoration: none; color: var(--color-text-muted);
		padding: 0.75rem 0; font-size: 0.95rem; font-weight: 400;
		transition: all 0.3s; display: flex; align-items: center; gap: 1rem;
	}
	.nav-item:hover, .nav-item.active { color: var(--color-text); }
	
	.nav-icon {
		color: var(--color-primary);
		opacity: 0.7;
		transition: opacity 0.3s;
	}
	.nav-item:hover .nav-icon, .nav-item.active .nav-icon {
		opacity: 1;
	}

	.user-pill {
		background: var(--color-card); border: 1px solid var(--color-border);
		padding: 1rem; border-radius: 12px; display: flex; align-items: center; gap: 0.75rem;
	}
	.user-avatar { 
		width: 32px; height: 32px; background: var(--color-primary-dim); 
		color: var(--color-primary); display: flex; align-items: center; 
		justify-content: center; font-size: 0.75rem; border-radius: 6px; font-weight: 600;
	}
	.user-name { display: block; font-size: 0.85rem; font-weight: 500; }
	.user-role { font-size: 0.7rem; color: var(--color-text-muted); }

	/* --- Main Content --- */
	.main { flex-grow: 1; display: flex; flex-direction: column; min-width: 0; }
	
	.header {
		padding: 2rem 3rem; display: flex; justify-content: space-between; align-items: center;
		border-bottom: 1px solid var(--color-border);
	}
	.search { display: flex; align-items: center; gap: 0.75rem; background: var(--color-surface); padding: 0.6rem 1.2rem; border-radius: 100px; border: 1px solid var(--color-border); }
	.search input { background: transparent; border: none; color: var(--color-text); font-size: 0.9rem; outline: none; width: 200px; }
	.search-icon { font-size: 0.9rem; opacity: 0.5; }

	.btn-primary { background: var(--color-primary); color: var(--color-bg); border: none; padding: 0.6rem 1.5rem; border-radius: 100px; font-weight: 600; font-size: 0.85rem; cursor: pointer; }
	.btn-secondary { background: transparent; color: var(--color-text); border: 1px solid var(--color-border); padding: 0.6rem 1.5rem; border-radius: 100px; font-size: 0.85rem; cursor: pointer; margin-right: 1rem; }

	.scroll-container { flex-grow: 1; overflow-y: auto; padding: 3rem; }
	.view { max-width: 1200px; margin: 0 auto; }

	.hero { margin-bottom: 4rem; }
	.hero h1 { font-size: 4.5rem; line-height: 0.95; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }
	.subtitle { color: var(--color-text-muted); font-size: 1.1rem; max-width: 400px; }

	/* --- Grid & Cards --- */
	.grid-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; }
	.stats-grid { grid-column: span 2; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 1rem; }
	
	.stat-card {
		background: var(--color-card); border: 1px solid var(--color-border);
		padding: 2rem; border-radius: 20px;
	}
	.stat-label { color: var(--color-text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 1rem; }
	.stat-main { display: flex; align-items: baseline; gap: 1rem; }
	.stat-value { font-size: 2.5rem; font-family: var(--font-serif); }
	.stat-trend { font-size: 0.8rem; padding: 0.2rem 0.5rem; border-radius: 4px; }
	.stat-trend.up { color: #a7f3d0; background: rgba(167, 243, 208, 0.1); }
	.stat-trend.down { color: #fecaca; background: rgba(254, 202, 202, 0.1); }

	.card { background: var(--color-card); border: 1px solid var(--color-border); border-radius: 24px; padding: 2rem; }
	.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
	.card-header h2 { font-size: 1.8rem; }
	.text-btn { background: transparent; border: none; color: var(--color-primary); cursor: pointer; font-size: 0.9rem; }

	.project-items { display: flex; flex-direction: column; gap: 2rem; }
	.p-header { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.75rem; }
	.p-cat { font-size: 0.7rem; text-transform: uppercase; color: var(--color-primary); letter-spacing: 0.1em; }
	.p-title { font-size: 1.1rem; font-weight: 500; }
	.p-progress { display: flex; align-items: center; gap: 1rem; }
	.p-bar { flex-grow: 1; height: 2px; background: var(--color-border); border-radius: 100px; overflow: hidden; }
	.p-fill { height: 100%; background: var(--color-primary); border-radius: 100px; }
	.p-num { font-size: 0.8rem; color: var(--color-text-muted); min-width: 35px; }

	.activity-items { display: flex; flex-direction: column; gap: 1.5rem; }
	.a-item { display: flex; gap: 1.5rem; align-items: flex-start; }
	.a-time { font-size: 0.8rem; color: var(--color-text-muted); min-width: 70px; padding-top: 0.2rem; }
	.a-desc { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.5; }
	.white { color: var(--color-text); font-weight: 500; }

	/* --- Custom Scrollbar --- */
	.scroll-container::-webkit-scrollbar { width: 4px; }
	.scroll-container::-webkit-scrollbar-track { background: transparent; }
	.scroll-container::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 10px; }

	/* --- Mobile --- */
	@media (max-width: 900px) {
		.app { flex-direction: column; height: auto; overflow: visible; }
		.sidebar { 
			width: 100%; height: auto; position: fixed; bottom: 0; z-index: 100;
			flex-direction: row; padding: 1rem; border-right: none; border-top: 1px solid var(--color-border);
			background: rgba(10, 9, 8, 0.95); backdrop-filter: blur(10px);
		}
		.brand, .sidebar-bottom { display: none; }
		.nav { flex-direction: row; justify-content: space-around; width: 100%; gap: 0; }
		.nav-item { flex-direction: column; font-size: 0.65rem; padding: 0.5rem; gap: 0.2rem; }
		.nav-icon { width: 20px; height: 20px; }

		.main { height: auto; padding-bottom: 80px; }
		.header { padding: 1rem 1.5rem; }
		.scroll-container { padding: 1.5rem; overflow: visible; }
		.hero h1 { font-size: 2.8rem; }
		.grid-layout { grid-template-columns: 1fr; }
		.stats-grid { grid-template-columns: 1fr; grid-column: span 1; gap: 1rem; }
		.search input { width: 100px; }
	}
</style>
