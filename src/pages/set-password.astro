---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Set Password | Gentlemen's Dashboard">
	<div class="setup-page">
		<div class="setup-card card">
			<div class="brand">
				<div class="logo">G</div>
				<h1 class="serif">Gentlemen</h1>
			</div>

			<p class="subtitle">Welcome, Gentleman. Please set a password to secure your account.</p>

			<div id="loading-state" class="status-text">Verifying your invitation...</div>

			<form id="set-password-form" style="display: none;">
				<div class="form-group">
					<label for="new_password">Password</label>
					<input type="password" id="new_password" name="new_password" placeholder="Min. 6 characters" required />
				</div>
				<div class="form-group">
					<label for="confirm_password">Confirm Password</label>
					<input type="password" id="confirm_password" name="confirm_password" required />
				</div>

				<div id="error-message" class="error-text"></div>

				<button type="submit" class="btn-primary full-width">Set Password & Continue</button>
			</form>

			<div id="error-state" class="error-text" style="display: none;">
				Invalid or expired invitation link. <a href="/login" class="gold-link">Back to login</a>.
			</div>
		</div>
	</div>
</Layout>

<script>
	import { supabase } from '../lib/supabase';

	const loadingEl = document.getElementById('loading-state');
	const formEl = document.getElementById('set-password-form') as HTMLFormElement;
	const errorStateEl = document.getElementById('error-state');
	const errorMessageEl = document.getElementById('error-message');

	function showForm() {
		if (loadingEl) loadingEl.style.display = 'none';
		if (formEl) formEl.style.display = 'block';
	}

	function showError() {
		if (loadingEl) loadingEl.style.display = 'none';
		if (errorStateEl) errorStateEl.style.display = 'block';
	}

	// Supabase auto-processes the hash (access_token) from the invite URL.
	// Listen for the resulting SIGNED_IN event to know when the session is ready.
	const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {
		if (event === 'SIGNED_IN' && session) {
			subscription.unsubscribe();
			showForm();
		}
	});

	// If already signed in (e.g. page refresh), show form immediately.
	supabase.auth.getSession().then(({ data: { session } }) => {
		if (session) {
			showForm();
		} else {
			// Give Supabase a moment to process the hash before showing error
			setTimeout(() => {
				supabase.auth.getSession().then(({ data: { session: s } }) => {
					if (!s) showError();
				});
			}, 3000);
		}
	});

	formEl?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!errorMessageEl) return;
		errorMessageEl.textContent = '';

		const formData = new FormData(formEl);
		const newPassword = formData.get('new_password') as string;
		const confirmPassword = formData.get('confirm_password') as string;

		if (newPassword !== confirmPassword) {
			errorMessageEl.textContent = 'Passwords do not match.';
			return;
		}

		if (newPassword.length < 6) {
			errorMessageEl.textContent = 'Password must be at least 6 characters.';
			return;
		}

		const submitBtn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
		submitBtn.textContent = 'Setting password...';
		submitBtn.disabled = true;

		const { error } = await supabase.auth.updateUser({ password: newPassword });

		if (error) {
			errorMessageEl.textContent = error.message;
			submitBtn.textContent = 'Set Password & Continue';
			submitBtn.disabled = false;
		} else {
			window.location.href = '/account?setup=true&mfa=prompt';
		}
	});
</script>

<style>
	.setup-page {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		background: var(--color-bg);
		padding: 2rem;
	}

	.setup-card {
		width: 100%;
		max-width: 420px;
		text-align: center;
		padding: 3rem 2rem;
	}

	.brand {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.logo {
		width: 48px; height: 48px; border: 1px solid var(--color-primary);
		color: var(--color-primary); display: flex; align-items: center;
		justify-content: center; font-family: var(--font-serif); font-size: 1.8rem;
	}

	h1 { font-size: 2.5rem; letter-spacing: -0.02em; }
	.subtitle { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 2.5rem; }

	.status-text {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		font-style: italic;
		padding: 1rem 0;
	}

	.form-group {
		text-align: left;
		margin-bottom: 1.5rem;
	}

	label {
		display: block;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-text-muted);
		margin-bottom: 0.5rem;
	}

	input {
		width: 100%;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		padding: 0.8rem 1rem;
		border-radius: 8px;
		outline: none;
		transition: border-color 0.3s;
	}

	input:focus { border-color: var(--color-primary); }

	.error-text {
		color: #fecaca;
		font-size: 0.85rem;
		margin-bottom: 1rem;
		min-height: 1.2rem;
	}

	.full-width {
		width: 100%;
		padding: 1rem;
		font-size: 1rem;
	}

	.gold-link { color: var(--color-primary); text-decoration: underline; }
</style>
