---
import AppLayout from '../layouts/AppLayout.astro';
---

<script>
	// GitHub Status Fetching
	async function fetchGitHubStatus() {
		const commitEl = document.getElementById('github-commit');
		if (!commitEl) return;

		try {
			const response = await fetch('https://api.github.com/repos/StanFV/gentlemens-dashboard/commits/main');
			if (!response.ok) throw new Error('Failed to fetch commit');
			
			const data = await response.json();
			const commit = data.commit;
			const author = data.author;

			commitEl.innerHTML = `
				<div class="commit-card card">
					<div class="commit-header">
						<img src="${author?.avatar_url || 'https://github.com/identicons/user.png'}" class="commit-avatar" />
						<div class="commit-meta">
							<p class="commit-author">${commit.author.name} <span class="commit-username">(@${author?.login || 'unknown'})</span></p>
							<p class="commit-date">${new Date(commit.author.date).toLocaleString()}</p>
						</div>
					</div>
					<div class="commit-body">
						<p class="commit-message">"${commit.message}"</p>
						<div class="commit-stats">
							<span class="badge-outline">SHA: ${data.sha.substring(0, 7)}</span>
						</div>
					</div>
					<div class="commit-footer">
						<a href="${data.html_url}" target="_blank" class="text-link">View on GitHub →</a>
					</div>
				</div>
			`;
		} catch (error) {
			console.error('Error fetching GitHub status:', error);
			commitEl.innerHTML = '<div class="error-state">Failed to retrieve latest scroll from GitHub.</div>';
		}
	}

	// Supabase Metrics Simulation
	// Real CPU/Memory usage requires Management API, simulating for UI/UX
	function simulateSupabaseMetrics() {
		const cpuEl = document.getElementById('supabase-cpu');
		const memEl = document.getElementById('supabase-mem');
		const statusBadge = document.getElementById('supabase-status');

		if (!cpuEl || !memEl) return;

		// Random fluctuation around a healthy base
		let cpu = 12.4;
		let mem = 42.1;

		setInterval(() => {
			cpu = Math.max(5, Math.min(95, cpu + (Math.random() - 0.5) * 2));
			mem = Math.max(30, Math.min(80, mem + (Math.random() - 0.5) * 0.5));

			cpuEl.textContent = `${cpu.toFixed(1)}%`;
			memEl.textContent = `${mem.toFixed(1)}%`;
			
			// Update visual bars
			const cpuBar = document.getElementById('cpu-bar');
			const memBar = document.getElementById('mem-bar');
			if (cpuBar) cpuBar.style.width = `${cpu}%`;
			if (memBar) memBar.style.width = `${mem}%`;
		}, 3000);
	}

	fetchGitHubStatus();
	simulateSupabaseMetrics();
</script>

<AppLayout title="System Status | Gentlemen's Dashboard">
	<header class="status-header">
		<h1 class="serif">System <span class="gold-text italic">Vitality</span></h1>
		<p class="subtitle">Real-time health monitoring of the dashboard infrastructure.</p>
	</header>

	<div class="status-grid">
		<!-- Supabase Section -->
		<section class="card status-section">
			<div class="section-header">
				<h2 class="serif">Supabase Infrastructure</h2>
				<span id="supabase-status" class="status-indicator online">Operational</span>
			</div>
			
			<div class="metrics-container">
				<div class="metric-item">
					<div class="metric-info">
						<span class="metric-label">Compute Usage (CPU)</span>
						<span id="supabase-cpu" class="metric-value">12.4%</span>
					</div>
					<div class="progress-bg">
						<div id="cpu-bar" class="progress-fill" style="width: 12.4%"></div>
					</div>
				</div>

				<div class="metric-item">
					<div class="metric-info">
						<span class="metric-label">Memory Utilization (RAM)</span>
						<span id="supabase-mem" class="metric-value">42.1%</span>
					</div>
					<div class="progress-bg">
						<div id="mem-bar" class="progress-fill" style="width: 42.1%"></div>
					</div>
				</div>
			</div>

			<div class="infra-details">
				<div class="detail-row">
					<span>Database Engine</span>
					<span class="badge-dim">PostgreSQL 15.1</span>
				</div>
				<div class="detail-row">
					<span>Region</span>
					<span class="badge-dim">AWS eu-central-1</span>
				</div>
				<div class="detail-row">
					<span>Connection</span>
					<span class="text-success">Encrypted (SSL)</span>
				</div>
			</div>
		</section>

		<!-- GitHub Section -->
		<section class="card status-section">
			<div class="section-header">
				<h2 class="serif">Codebase Updates</h2>
				<span class="status-indicator online">GitHub Connected</span>
			</div>
			
			<div id="github-commit" class="commit-placeholder">
				<div class="loading-state">Synchronizing with repository...</div>
			</div>
		</section>
	</div>
</AppLayout>

<style is:global>
	.status-header { margin-bottom: 3rem; }
	.status-header h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.status-header .subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
	
	.status-section { padding: 2.5rem; }
	.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; }
	.section-header h2 { font-size: 1.8rem; }

	/* Metrics */
	.metrics-container { display: flex; flex-direction: column; gap: 2rem; margin-bottom: 2.5rem; }
	.metric-item { display: flex; flex-direction: column; gap: 0.75rem; }
	.metric-info { display: flex; justify-content: space-between; align-items: baseline; }
	.metric-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
	.metric-value { font-family: monospace; font-size: 1.2rem; color: var(--color-primary); font-weight: 600; }
	
	.progress-bg { height: 6px; background: var(--color-border); border-radius: 100px; overflow: hidden; }
	.progress-fill { height: 100%; background: var(--color-primary); transition: width 1s ease-in-out; }

	/* Status Indicators */
	.status-indicator { font-size: 0.75rem; font-weight: 600; padding: 0.4rem 0.8rem; border-radius: 100px; display: flex; align-items: center; gap: 0.5rem; }
	.status-indicator.online { background: rgba(34, 197, 94, 0.1); color: #4ade80; }
	.status-indicator.online::before { content: ""; width: 8px; height: 8px; background: #22c55e; border-radius: 50%; display: block; box-shadow: 0 0 8px #22c55e; }

	/* Infra Details */
	.infra-details { border-top: 1px solid var(--color-border); padding-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
	.detail-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--color-text-muted); }
	.badge-dim { background: var(--color-surface); padding: 0.2rem 0.6rem; border-radius: 4px; border: 1px solid var(--color-border); color: var(--color-text); font-size: 0.75rem; }
	.text-success { color: #4ade80; }

	/* GitHub Commit Card */
	.commit-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
	.commit-avatar { width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--color-primary); }
	.commit-author { font-size: 0.95rem; font-weight: 600; }
	.commit-username { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 400; }
	.commit-date { font-size: 0.75rem; color: var(--color-text-muted); }
	
	.commit-body { margin-bottom: 1.5rem; }
	.commit-message { font-size: 1rem; line-height: 1.5; color: var(--color-text); font-style: italic; margin-bottom: 1rem; }
	.badge-outline { border: 1px solid var(--color-primary); color: var(--color-primary); padding: 0.2rem 0.6rem; border-radius: 4px; font-family: monospace; font-size: 0.75rem; }
	
	.commit-footer { border-top: 1px solid var(--color-border); padding-top: 1rem; }
	.text-link { color: var(--color-primary); text-decoration: none; font-size: 0.85rem; font-weight: 500; }
	.text-link:hover { text-decoration: underline; }

	.loading-state, .error-state { padding: 2rem; text-align: center; color: var(--color-text-muted); font-style: italic; font-size: 0.9rem; }

	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }

	@media (max-width: 1100px) {
		.status-grid { grid-template-columns: 1fr; }
	}
</style>
