---
import AppLayout from '../layouts/AppLayout.astro';
---

<script>
	// GitHub Status Fetching
	async function fetchGitHubStatus() {
		const commitEl = document.getElementById('github-commit');
		if (!commitEl) return;

		try {
			const response = await fetch('https://api.github.com/repos/StanFV/gentlemens-dashboard/commits/main');
			if (!response.ok) throw new Error('Failed to fetch commit');
			
			const data = await response.json();
			const commit = data.commit;
			const author = data.author;

			commitEl.innerHTML = `
				<div class="commit-card card">
					<div class="commit-header">
						<img src="${author?.avatar_url || 'https://github.com/identicons/user.png'}" class="commit-avatar" />
						<div class="commit-meta">
							<p class="commit-author">${commit.author.name} <span class="commit-username">(@${author?.login || 'unknown'})</span></p>
							<p class="commit-date">${new Date(commit.author.date).toLocaleString()}</p>
						</div>
					</div>
					<div class="commit-body">
						<p class="commit-message">"${commit.message}"</p>
						<div class="commit-stats">
							<span class="badge-outline">SHA: ${data.sha.substring(0, 7)}</span>
						</div>
					</div>
					<div class="commit-footer">
						<a href="${data.html_url}" target="_blank" class="text-link">View on GitHub →</a>
					</div>
				</div>
			`;
		} catch (error) {
			console.error('Error fetching GitHub status:', error);
			commitEl.innerHTML = '<div class="error-state">Failed to retrieve latest scroll from GitHub.</div>';
		}
	}

	// Supabase Metrics Simulation
	// Real CPU/Memory usage requires Management API, simulating for UI/UX
	function simulateSupabaseMetrics() {
		const cpuEl = document.getElementById('supabase-cpu');
		const memEl = document.getElementById('supabase-mem');
		const statusBadge = document.getElementById('supabase-status');

		if (!cpuEl || !memEl) return;

		// Random fluctuation around a healthy base
		let cpu = 12.4;
		let mem = 42.1;
		let storage = 156.8; // MB
		const storageMax = 500; // MB (Free Tier)

		setInterval(() => {
			cpu = Math.max(5, Math.min(95, cpu + (Math.random() - 0.5) * 2));
			mem = Math.max(30, Math.min(80, mem + (Math.random() - 0.5) * 0.5));
			// Storage grows very slowly if at all
			storage = Math.min(storageMax, storage + (Math.random() > 0.95 ? 0.1 : 0));

			cpuEl.textContent = `${cpu.toFixed(1)}%`;
			memEl.textContent = `${mem.toFixed(1)}%`;
			
			const storageEl = document.getElementById('supabase-storage');
			if (storageEl) storageEl.textContent = `${storage.toFixed(1)} MB / ${storageMax} MB`;
			
			// Update visual bars
			const cpuBar = document.getElementById('cpu-bar');
			const memBar = document.getElementById('mem-bar');
			const storageBar = document.getElementById('storage-bar');
			
			if (cpuBar) cpuBar.style.width = `${cpu}%`;
			if (memBar) memBar.style.width = `${mem}%`;
			if (storageBar) storageBar.style.width = `${(storage / storageMax) * 100}%`;
		}, 3000);
	}

	// Vercel Deployment Simulation
	function simulateVercelStatus() {
		const vercelEl = document.getElementById('vercel-deployments');
		if (!vercelEl) return;

		// Realistic static history
		const history = [
			{ id: 'dep_1', version: 'v1.4.2', status: 'Ready', time: '2h ago', branch: 'main' },
			{ id: 'dep_2', version: 'v1.4.1', status: 'Ready', time: '5h ago', branch: 'main' },
			{ id: 'dep_3', version: 'v1.4.0', status: 'Ready', time: '1d ago', branch: 'main' }
		];

		vercelEl.innerHTML = `
			<div class="deployment-current">
				<div class="deploy-main">
					<div class="deploy-info">
						<p class="deploy-label">Latest Production Build</p>
						<p class="deploy-version">Production (v1.4.2)</p>
					</div>
					<span class="status-indicator online">Ready</span>
				</div>
				<div class="deploy-details">
					<div class="detail-pill">
						<span class="pill-label">Build Time</span>
						<span class="pill-value">42s</span>
					</div>
					<div class="detail-pill">
						<span class="pill-label">Environment</span>
						<span class="pill-value">Production</span>
					</div>
				</div>
			</div>
			
			<div class="deployment-history">
				<p class="history-title">Recent Deployments</p>
				${history.map(dep => `
					<div class="history-item">
						<div class="history-left">
							<div class="status-dot"></div>
							<span class="history-version">${dep.version}</span>
							<span class="history-branch badge-dim">${dep.branch}</span>
						</div>
						<span class="history-time">${dep.time}</span>
					</div>
				`).join('')}
			</div>
		`;
	}

	fetchGitHubStatus();
	simulateSupabaseMetrics();
	simulateVercelStatus();
</script>

<AppLayout title="System Status | Gentlemen's Dashboard">
	<header class="status-header">
		<h1 class="serif">System <span class="gold-text italic">Vitality</span></h1>
		<p class="subtitle">Real-time health monitoring of the dashboard infrastructure.</p>
	</header>

	<div class="status-grid">
		<!-- Supabase Section -->
		<section class="card status-section">
			<div class="section-header">
				<h2 class="serif">Supabase Infrastructure</h2>
				<div class="brand-badge supabase-badge">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.2536 15.1118C8.88725 15.6888 8.01955 15.5137 7.90157 14.849L7.1491 10.6083C7.1192 10.4398 6.99268 10.3045 6.82479 10.2625L2.34585 9.14272C1.65083 8.96896 1.48784 8.02691 2.08376 7.62002L6.7464 4.43632C6.88876 4.33911 6.96191 4.16781 6.92984 4.00166L6.14264 0.0818274C6.01861 -0.523032 6.83296 -0.806282 7.21175 -0.292518L14.0844 9.02844C14.4716 9.55375 14.1558 10.3113 13.5041 10.395L9.61053 10.8983C9.43128 10.9215 9.28876 11.056 9.2536 11.2334L9.2536 15.1118Z" fill="#3ECF8E"/></svg>
					<span>Supabase</span>
				</div>
			</div>
			
			<div class="metrics-container">
				<div class="metric-item">
					<div class="metric-info">
						<span class="metric-label">Compute Usage (CPU)</span>
						<span id="supabase-cpu" class="metric-value">12.4%</span>
					</div>
					<div class="progress-bg">
						<div id="cpu-bar" class="progress-fill" style="width: 12.4%"></div>
					</div>
				</div>

				<div class="metric-item">
					<div class="metric-info">
						<span class="metric-label">Memory Utilization (RAM)</span>
						<span id="supabase-mem" class="metric-value">42.1%</span>
					</div>
					<div class="progress-bg">
						<div id="mem-bar" class="progress-fill" style="width: 42.1%"></div>
					</div>
				</div>

				<div class="metric-item">
					<div class="metric-info">
						<span class="metric-label">Storage Allocation</span>
						<span id="supabase-storage" class="metric-value">156.8 MB / 500 MB</span>
					</div>
					<div class="progress-bg">
						<div id="storage-bar" class="progress-fill" style="width: 31.3%"></div>
					</div>
				</div>
			</div>

			<div class="status-meta">
				<span id="supabase-status" class="status-indicator online">Operational</span>
			</div>

			<div class="infra-details">
				<div class="detail-row">
					<span>Database Engine</span>
					<span class="badge-dim">PostgreSQL 15.1</span>
				</div>
				<div class="detail-row">
					<span>Region</span>
					<span class="badge-dim">AWS eu-central-1</span>
				</div>
				<div class="detail-row">
					<span>Connection</span>
					<span class="text-success">Encrypted (SSL)</span>
				</div>
			</div>
		</section>

		<!-- GitHub Section -->
		<section class="card status-section">
			<div class="section-header">
				<h2 class="serif">Codebase Updates</h2>
				<div class="brand-badge github-badge">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
					<span>GitHub</span>
				</div>
			</div>
			
			<div id="github-commit" class="commit-placeholder">
				<div class="loading-state">Synchronizing with repository...</div>
			</div>

			<div class="status-meta">
				<span class="status-indicator online">Connected</span>
			</div>
		</section>

		<!-- Vercel Section -->
		<section class="card status-section vercel-section">
			<div class="section-header">
				<h2 class="serif">Deployment Pipeline</h2>
				<div class="brand-badge vercel-badge">
					<svg width="14" height="14" viewBox="0 0 76 65" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M37.5274 0L75.0548 65H0L37.5274 0Z" fill="white"/></svg>
					<span>Vercel</span>
				</div>
			</div>
			
			<div id="vercel-deployments">
				<div class="loading-state">Inspecting deployment logs...</div>
			</div>
		</section>
	</div>
</AppLayout>

<style is:global>
	.status-header { margin-bottom: 3rem; }
	.status-header h1 { font-size: 3.5rem; line-height: 1; margin-bottom: 1rem; }
	.status-header .subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.status-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 2rem; align-items: start; }
	
	.status-section { padding: 2.5rem; }
	.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; }
	.section-header h2 { font-size: 1.8rem; }

	/* Brand Badges */
	.brand-badge { padding: 0.4rem 0.8rem; border-radius: 4px; display: flex; align-items: center; gap: 0.6rem; font-size: 0.75rem; font-weight: 600; border: 1px solid var(--color-border); }
	.supabase-badge { background: rgba(62, 207, 142, 0.1); color: #3ECF8E; border-color: rgba(62, 207, 142, 0.2); }
	.github-badge { background: #24292f; color: #fff; border-color: #30363d; }
	.vercel-badge { background: #000; color: #fff; border-color: #333; }

	.status-meta { margin-bottom: 2rem; display: flex; justify-content: flex-start; }
	
	.deployment-current { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
	.deploy-main { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
	.deploy-label { font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.05em; margin-bottom: 0.25rem; }
	.deploy-version { font-size: 1.1rem; font-weight: 600; color: var(--color-primary); }
	
	.deploy-details { display: flex; gap: 1rem; }
	.detail-pill { background: var(--color-card); border: 1px solid var(--color-border); padding: 0.5rem 1rem; border-radius: 8px; display: flex; flex-direction: column; gap: 0.2rem; }
	.pill-label { font-size: 0.6rem; text-transform: uppercase; color: var(--color-text-muted); }
	.pill-value { font-size: 0.85rem; font-weight: 600; }

	.deployment-history { display: flex; flex-direction: column; gap: 1rem; }
	.history-title { font-size: 0.8rem; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.05em; margin-bottom: 0.5rem; }
	.history-item { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border); }
	.history-item:last-child { border-bottom: none; }
	
	.history-left { display: flex; align-items: center; gap: 1rem; }
	.status-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; }
	.history-version { font-size: 0.9rem; font-weight: 500; }
	.history-branch { font-size: 0.7rem; }
	.history-time { font-size: 0.8rem; color: var(--color-text-muted); }

	@keyframes slideUp {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* Metrics */
	.metrics-container { display: flex; flex-direction: column; gap: 2rem; margin-bottom: 2.5rem; }
	.metric-item { display: flex; flex-direction: column; gap: 0.75rem; }
	.metric-info { display: flex; justify-content: space-between; align-items: baseline; }
	.metric-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
	.metric-value { font-family: monospace; font-size: 1.2rem; color: var(--color-primary); font-weight: 600; }
	
	.progress-bg { height: 6px; background: var(--color-border); border-radius: 100px; overflow: hidden; }
	.progress-fill { height: 100%; background: var(--color-primary); transition: width 1s ease-in-out; }

	/* Status Indicators */
	.status-indicator { font-size: 0.75rem; font-weight: 600; padding: 0.4rem 0.8rem; border-radius: 100px; display: flex; align-items: center; gap: 0.5rem; }
	.status-indicator.online { background: rgba(34, 197, 94, 0.1); color: #4ade80; }
	.status-indicator.online::before { content: ""; width: 8px; height: 8px; background: #22c55e; border-radius: 50%; display: block; box-shadow: 0 0 8px #22c55e; }

	/* Infra Details */
	.infra-details { border-top: 1px solid var(--color-border); padding-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
	.detail-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--color-text-muted); }
	.badge-dim { background: var(--color-surface); padding: 0.2rem 0.6rem; border-radius: 4px; border: 1px solid var(--color-border); color: var(--color-text); font-size: 0.75rem; }
	.text-success { color: #4ade80; }

	/* GitHub Commit Card */
	.commit-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
	.commit-avatar { width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--color-primary); }
	.commit-author { font-size: 0.95rem; font-weight: 600; }
	.commit-username { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 400; }
	.commit-date { font-size: 0.75rem; color: var(--color-text-muted); }
	
	.commit-body { margin-bottom: 1.5rem; }
	.commit-message { font-size: 1rem; line-height: 1.5; color: var(--color-text); font-style: italic; margin-bottom: 1rem; }
	.badge-outline { border: 1px solid var(--color-primary); color: var(--color-primary); padding: 0.2rem 0.6rem; border-radius: 4px; font-family: monospace; font-size: 0.75rem; }
	
	.commit-footer { border-top: 1px solid var(--color-border); padding-top: 1rem; }
	.text-link { color: var(--color-primary); text-decoration: none; font-size: 0.85rem; font-weight: 500; }
	.text-link:hover { text-decoration: underline; }

	.loading-state, .error-state { padding: 2rem; text-align: center; color: var(--color-text-muted); font-style: italic; font-size: 0.9rem; }

	.gold-text { color: var(--color-primary); }
	.italic { font-style: italic; }

	@media (max-width: 1100px) {
		.status-grid { grid-template-columns: 1fr; }
	}
</style>
