---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Feature Checklist">
	<div class="features-view">
		<div class="page-header">
			<div class="header-content">
				<h1 class="serif">Feature Checklist</h1>
				<p class="subtitle">Beheer dashboard feature requests en toewijzingen.</p>
			</div>
			<button id="open-modal-btn" class="btn-primary">Nieuwe Request</button>
		</div>

		<div class="list-filters card">
			<div class="filter-group">
				<button class="filter-btn active" data-status="all">Alles</button>
				<button class="filter-btn" data-status="pending">Pending</button>
				<button class="filter-btn" data-status="planned">Planned</button>
				<button class="filter-btn" data-status="in-progress">In Progress</button>
				<button class="filter-btn" data-status="completed">Completed</button>
			</div>
		</div>
		
		<div id="features-loading" class="loading">Gegevens laden...</div>
		<div id="features-empty" class="empty-state" style="display: none;">Geen feature requests gevonden.</div>
		<div id="features-grid" class="features-grid"></div>
	</div>

	<!-- Modal for Adding/Editing -->
	<div id="feature-modal" class="modal">
		<div class="modal-content card">
			<div class="modal-header">
				<h3 id="modal-title">Nieuwe Request</h3>
				<button id="close-modal-btn" class="close-btn">&times;</button>
			</div>
			<form id="feature-form">
				<input type="hidden" id="feature-id" name="id" />
				<div class="form-group">
					<label for="title">Titel</label>
					<input type="text" id="title" name="title" placeholder="Wat moet er toegevoegd worden?" required />
				</div>
				<div class="form-group">
					<label for="description">Beschrijving</label>
					<textarea id="description" name="description" placeholder="Beschrijf de feature..." rows="4"></textarea>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="status">Status</label>
						<select id="status" name="status">
							<option value="pending">Pending</option>
							<option value="planned">Planned</option>
							<option value="in-progress">In Progress</option>
							<option value="completed">Completed</option>
						</select>
					</div>
					<div class="form-group">
						<label for="assigned_to">Toewijzen aan</label>
						<select id="assigned_to" name="assigned_to">
							<option value="">Niemand</option>
						</select>
					</div>
				</div>
				<div class="modal-actions">
					<button type="button" id="cancel-btn" class="btn-secondary">Annuleren</button>
					<button type="submit" class="btn-primary">Opslaan</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		import { supabase } from '../lib/supabase';

		const grid = document.getElementById('features-grid');
		const loading = document.getElementById('features-loading');
		const empty = document.getElementById('features-empty');
		const filterBtns = document.querySelectorAll('.filter-btn');
		const modal = document.getElementById('feature-modal');
		const form = document.getElementById('feature-form') as HTMLFormElement;
		const userSelect = document.getElementById('assigned_to') as HTMLSelectElement;
		
		let currentStatus = 'all';
		let allProfiles = [];

		async function loadUsers() {
			const { data } = await supabase.from('profiles').select('id, full_name, username');
			if (data) {
				allProfiles = data;
				data.forEach(profile => {
					const option = document.createElement('option');
					option.value = profile.id;
					option.textContent = profile.full_name || profile.username;
					userSelect.appendChild(option);
				});
			}
		}

		async function loadFeatures() {
			loading!.style.display = 'block';
			grid!.innerHTML = '';
			empty!.style.display = 'none';

			let query = supabase
				.from('feature_requests')
				.select(`
					*,
					assignee:profiles!assigned_to (
						id,
						full_name,
						username,
						avatar_url
					)
				`)
				.order('created_at', { ascending: false });

			if (currentStatus !== 'all') {
				query = query.eq('status', currentStatus);
			}

			const { data, error } = await query;
			loading!.style.display = 'none';

			if (error) {
				console.error('Error loading features:', error);
				return;
			}

			if (!data || data.length === 0) {
				empty!.style.display = 'block';
				return;
			}

			data.forEach(feature => {
				const card = document.createElement('div');
				card.className = 'feature-card card';
				
				const assignee = feature.assignee;
				const assigneeName = assignee ? (assignee.full_name || assignee.username) : 'Niet toegewezen';
				const assigneeAvatar = assignee?.avatar_url || `https://ui-avatars.com/api/?name=${assigneeName}&background=1c1917&color=c5a059`;

				card.innerHTML = `
					<div class="feature-content">
						<div class="feature-top">
							<span class="status-badge status-${feature.status}">${feature.status}</span>
							<button class="edit-btn" data-id="${feature.id}">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
							</button>
						</div>
						<h3 class="feature-title">${feature.title}</h3>
						<p class="feature-desc">${feature.description || 'Geen beschrijving.'}</p>
						<div class="feature-footer">
							<div class="assignee-info">
								<img src="${assigneeAvatar}" class="assignee-avatar-small" />
								<span>${assigneeName}</span>
							</div>
							<span class="date">${new Date(feature.created_at).toLocaleDateString()}</span>
						</div>
					</div>
				`;
				grid?.appendChild(card);
			});

			document.querySelectorAll('.edit-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const id = (e.currentTarget as HTMLButtonElement).dataset.id;
					const feature = data.find(f => f.id === id);
					if (feature) openEditModal(feature);
				});
			});
		}

		function openEditModal(feature) {
			document.getElementById('modal-title')!.textContent = 'Request Bewerken';
			document.getElementById('feature-id')!.setAttribute('value', feature.id);
			(document.getElementById('title') as HTMLInputElement).value = feature.title;
			(document.getElementById('description') as HTMLTextAreaElement).value = feature.description || '';
			(document.getElementById('status') as HTMLSelectElement).value = feature.status;
			(document.getElementById('assigned_to') as HTMLSelectElement).value = feature.assigned_to || '';
			modal!.style.display = 'flex';
		}

		document.getElementById('open-modal-btn')?.addEventListener('click', () => {
			document.getElementById('modal-title')!.textContent = 'Nieuwe Request';
			form.reset();
			document.getElementById('feature-id')!.setAttribute('value', '');
			modal!.style.display = 'flex';
		});

		const closeModal = () => modal!.style.display = 'none';
		document.getElementById('close-modal-btn')?.addEventListener('click', closeModal);
		document.getElementById('cancel-btn')?.addEventListener('click', closeModal);

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const id = formData.get('id');
			const { data: { session } } = await supabase.auth.getSession();

			if (!session) return alert('Log in om dit te doen.');

			const payload = {
				title: formData.get('title'),
				description: formData.get('description'),
				status: formData.get('status'),
				assigned_to: formData.get('assigned_to') || null,
			};

			let error;
			if (id) {
				const { error: err } = await supabase.from('feature_requests').update(payload).eq('id', id);
				error = err;
			} else {
				const { error: err } = await supabase.from('feature_requests').insert({ ...payload, user_id: session.user.id });
				error = err;
			}

			if (error) alert('Fout: ' + error.message);
			else {
				closeModal();
				loadFeatures();
			}
		});

		filterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				filterBtns.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				currentStatus = (btn as HTMLButtonElement).dataset.status || 'all';
				loadFeatures();
			});
		});

		loadUsers();
		loadFeatures();
	</script>
</AppLayout>

<style>
	.features-view {
		width: 100%;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 3rem;
	}

	.page-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
	.subtitle { color: var(--color-text-muted); font-size: 1.1rem; }

	.list-filters {
		padding: 1rem;
		margin-bottom: 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.filter-group { display: flex; gap: 0.5rem; }

	.filter-btn {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		color: var(--color-text-muted);
		padding: 0.5rem 1.25rem;
		border-radius: 100px;
		font-size: 0.85rem;
		cursor: pointer;
		transition: all 0.3s;
	}

	.filter-btn:hover { border-color: var(--color-primary); color: var(--color-text); }
	.filter-btn.active { background: var(--color-primary); color: var(--color-bg); border-color: var(--color-primary); }

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 1.5rem;
	}

	.card {
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: 16px;
	}

	.feature-card {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		transition: transform 0.2s, border-color 0.2s;
	}

	.feature-card:hover {
		transform: translateY(-4px);
		border-color: var(--color-primary);
	}

	.feature-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
	}

	.edit-btn {
		background: transparent;
		border: none;
		color: var(--color-text-muted);
		cursor: pointer;
		padding: 0.5rem;
		border-radius: 8px;
		transition: all 0.2s;
	}

	.edit-btn:hover {
		background: var(--color-surface);
		color: var(--color-primary);
	}

	.feature-title { font-size: 1.25rem; margin-bottom: 0.75rem; }
	.feature-desc { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6; flex-grow: 1; margin-bottom: 1.5rem; }

	.feature-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
	}

	.assignee-info {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.85rem;
		font-weight: 500;
	}

	.assignee-avatar-small {
		width: 24px;
		height: 24px;
		border-radius: 6px;
		border: 1px solid var(--color-primary);
	}

	.date { font-size: 0.75rem; color: var(--color-text-muted); }

	.status-badge {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 700;
		padding: 0.25rem 0.75rem;
		border-radius: 100px;
	}

	.status-pending { background: #4b5563; color: white; }
	.status-planned { background: #2563eb; color: white; }
	.status-in-progress { background: #d97706; color: white; }
	.status-completed { background: #059669; color: white; }

	/* Modal */
	.modal {
		position: fixed;
		top: 0; left: 0; width: 100%; height: 100%;
		background: rgba(0,0,0,0.8);
		backdrop-filter: blur(4px);
		display: none;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		padding: 1rem;
	}

	.modal-content {
		width: 100%;
		max-width: 600px;
		padding: 2rem;
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}

	.close-btn {
		background: transparent;
		border: none;
		color: var(--color-text);
		font-size: 1.5rem;
		cursor: pointer;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.form-group { margin-bottom: 1.5rem; }
	.form-group label { display: block; margin-bottom: 0.5rem; font-size: 0.9rem; font-weight: 500; }
	.form-group input, .form-group textarea, .form-group select {
		width: 100%;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.75rem 1rem;
		color: var(--color-text);
		font-family: inherit;
		outline: none;
	}

	.modal-actions {
		display: flex;
		justify-content: flex-end;
		gap: 1rem;
		margin-top: 1rem;
	}

	.loading, .empty-state {
		text-align: center;
		padding: 4rem;
		color: var(--color-text-muted);
		background: var(--color-card);
		border-radius: 16px;
		border: 1px dashed var(--color-border);
	}
</style>
