---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Feature Checklist">
	<div class="features-container">
		<div class="page-header">
			<h1 class="serif">Feature Checklist</h1>
			<p class="subtitle">Suggest and vote on new features for the dashboard.</p>
		</div>

		<div class="features-grid">
			<div class="feature-form card">
				<h3>Submit a Request</h3>
				<form id="feature-form">
					<div class="form-group">
						<label for="title">Title</label>
						<input type="text" id="title" name="title" placeholder="What should we add?" required />
					</div>
					<div class="form-group">
						<label for="description">Description</label>
						<textarea id="description" name="description" placeholder="Describe the feature in detail..." rows="4"></textarea>
					</div>
					<button type="submit" class="btn-primary" style="width: 100%;">Submit Request</button>
				</form>
			</div>

			<div class="feature-list">
				<div class="list-filters">
					<button class="filter-btn active" data-status="all">All</button>
					<button class="filter-btn" data-status="pending">Pending</button>
					<button class="filter-btn" data-status="planned">Planned</button>
					<button class="filter-btn" data-status="in-progress">In Progress</button>
					<button class="filter-btn" data-status="completed">Completed</button>
				</div>
				
				<div id="features-loading" class="loading">Loading requests...</div>
				<div id="features-empty" class="empty-state" style="display: none;">No feature requests found.</div>
				<div id="features-container" class="list-container"></div>
			</div>
		</div>
	</div>

	<script>
		import { supabase } from '../lib/supabase';

		const form = document.getElementById('feature-form') as HTMLFormElement;
		const container = document.getElementById('features-container');
		const loading = document.getElementById('features-loading');
		const empty = document.getElementById('features-empty');
		const filterBtns = document.querySelectorAll('.filter-btn');

		let currentStatus = 'all';

		async function loadFeatures() {
			loading!.style.display = 'block';
			container!.innerHTML = '';
			empty!.style.display = 'none';

			let query = supabase
				.from('feature_requests')
				.select(`
					*,
					profiles:assigned_to (
						full_name,
						username,
						avatar_url
					)
				`)
				.order('upvotes', { ascending: false });

			if (currentStatus !== 'all') {
				query = query.eq('status', currentStatus);
			}

			const { data, error } = await query;

			loading!.style.display = 'none';

			if (error) {
				console.error('Error loading features:', error);
				return;
			}

			if (!data || data.length === 0) {
				empty!.style.display = 'block';
				return;
			}

			data.forEach(feature => {
				const card = document.createElement('div');
				card.className = 'feature-card card';
				
				// Handle potential nested profile from Supabase join
				const assignee = feature.profiles;
				const assigneeName = assignee ? (assignee.full_name || assignee.username) : null;
				const assigneeAvatar = assignee?.avatar_url || `https://ui-avatars.com/api/?name=${assigneeName}&background=1c1917&color=c5a059`;

				card.innerHTML = `
					<div class="feature-vote">
						<button class="vote-btn" data-id="${feature.id}">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
							<span>${feature.upvotes}</span>
						</button>
					</div>
					<div class="feature-content">
						<div class="feature-top">
							<h4>${feature.title}</h4>
							<div class="feature-badges">
								${assigneeName ? `
									<span class="assignee-badge" title="Assigned to ${assigneeName}">
										<img src="${assigneeAvatar}" class="assignee-avatar" />
										${assigneeName}
									</span>
								` : ''}
								<span class="status-badge status-${feature.status}">${feature.status}</span>
							</div>
						</div>
						<p>${feature.description || 'No description provided.'}</p>
					</div>
				`;
				container?.appendChild(card);
			});

			// Add vote listeners
			document.querySelectorAll('.vote-btn').forEach(btn => {
				btn.addEventListener('click', async (e) => {
					const id = (e.currentTarget as HTMLButtonElement).dataset.id;
					if (id) upvote(id);
				});
			});
		}

		async function upvote(id: string) {
			const { error } = await supabase.rpc('upvote_feature_request', { request_id: id });
			if (error) {
				console.error('Error upvoting:', error);
			} else {
				loadFeatures();
			}
		}

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const { data: { session } } = await supabase.auth.getSession();

			if (!session) {
				alert('You must be logged in to submit a request.');
				return;
			}

			const { error } = await supabase.from('feature_requests').insert({
				title: formData.get('title'),
				description: formData.get('description'),
				user_id: session.user.id
			});

			if (error) {
				alert('Error submitting request: ' + error.message);
			} else {
				form.reset();
				loadFeatures();
			}
		});

		filterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				filterBtns.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				currentStatus = (btn as HTMLButtonElement).dataset.status || 'all';
				loadFeatures();
			});
		});

		loadFeatures();
	</script>
</AppLayout>

<style>
	.features-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.page-header {
		margin-bottom: 3rem;
	}

	.page-header h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--color-text-muted);
		font-size: 1.1rem;
	}

	.features-grid {
		display: grid;
		grid-template-columns: 350px 1fr;
		gap: 2rem;
		align-items: start;
	}

	.card {
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: 16px;
		padding: 2rem;
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.form-group input, .form-group textarea {
		width: 100%;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 0.75rem 1rem;
		color: var(--color-text);
		font-family: inherit;
		outline: none;
		transition: border-color 0.3s;
	}

	.form-group input:focus, .form-group textarea:focus {
		border-color: var(--color-primary);
	}

	.list-filters {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		color: var(--color-text-muted);
		padding: 0.5rem 1.25rem;
		border-radius: 100px;
		font-size: 0.85rem;
		cursor: pointer;
		transition: all 0.3s;
	}

	.filter-btn:hover {
		border-color: var(--color-primary);
		color: var(--color-text);
	}

	.filter-btn.active {
		background: var(--color-primary);
		color: var(--color-bg);
		border-color: var(--color-primary);
	}

	.list-container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.feature-card {
		display: flex;
		gap: 1.5rem;
		padding: 1.5rem;
		transition: transform 0.2s;
	}

	.feature-card:hover {
		transform: translateX(4px);
	}

	.feature-vote {
		flex-shrink: 0;
	}

	.vote-btn {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		padding: 0.75rem;
		border-radius: 12px;
		cursor: pointer;
		min-width: 50px;
		transition: all 0.3s;
	}

	.vote-btn:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.vote-btn span {
		font-weight: 700;
		font-size: 1rem;
	}

	.feature-content {
		flex-grow: 1;
	}

	.feature-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.5rem;
		gap: 1rem;
	}

	.feature-badges {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.assignee-badge {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.2rem 0.6rem;
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-text);
	}

	.assignee-avatar {
		width: 16px;
		height: 16px;
		border-radius: 4px;
		object-fit: cover;
		border: 1px solid var(--color-primary);
	}

	.feature-top h4 {
		font-size: 1.1rem;
		margin: 0;
	}

	.status-badge {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 700;
		padding: 0.25rem 0.75rem;
		border-radius: 100px;
	}

	.status-pending { background: #4b5563; color: white; }
	.status-planned { background: #2563eb; color: white; }
	.status-in-progress { background: #d97706; color: white; }
	.status-completed { background: #059669; color: white; }

	.feature-content p {
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.5;
		margin: 0;
	}

	.loading, .empty-state {
		text-align: center;
		padding: 4rem;
		color: var(--color-text-muted);
		background: var(--color-card);
		border-radius: 16px;
		border: 1px dashed var(--color-border);
	}

	@media (max-width: 900px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
